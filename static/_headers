# Cloudflare Pages cache headers.
#
# Hugo emits content-hashed filenames for the CSS/JS bundles into /css/, /ts/,
# and /vendor/ (fingerprinted via `| fingerprint`), so they're safe to mark
# `immutable, max-age=1y` — the hash changes whenever the content does. Fonts,
# textures, badges, and cover images are committed once and never mutate. HTML
# stays short-cached so content edits propagate quickly without a manual purge.

/css/*
  Cache-Control: public, max-age=31536000, immutable

/ts/*
  Cache-Control: public, max-age=31536000, immutable

/vendor/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/textures/*
  Cache-Control: public, max-age=31536000, immutable

/badges/*
  Cache-Control: public, max-age=31536000, immutable

/covers/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=2592000

# HTML — short browser cache, longer CDN cache with revalidation.
# stale-while-revalidate keeps the CDN responsive during a deploy.
# Security headers ride along on every response: nosniff stops MIME confusion
# on user-download paths (resume.pdf/docx), DENY blocks clickjacking framing,
# and the referrer policy keeps full URLs from leaking cross-origin. A CSP is
# deliberately absent for now — the templates use inline scripts and Alpine
# evaluates inline expressions, so a meaningful CSP needs nonce plumbing first.
/*
  Cache-Control: public, max-age=300, s-maxage=3600, stale-while-revalidate=86400
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
