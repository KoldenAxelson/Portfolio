{
  "$ref": "#/definitions/projects",
  "definitions": {
    "projects": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "tier": {
          "type": "number",
          "enum": [
            1,
            2,
            3
          ]
        },
        "summary": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "stack": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "role": {
          "type": "string"
        },
        "year": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "shipped",
            "in-progress",
            "abandoned",
            "classified"
          ],
          "default": "shipped"
        },
        "links": {
          "type": "object",
          "properties": {
            "live": {
              "type": "string",
              "format": "uri"
            },
            "repo": {
              "type": "string",
              "format": "uri"
            },
            "case_study": {
              "type": "string",
              "format": "uri"
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "metric": {
          "type": "object",
          "properties": {
            "label": {
              "type": "string"
            },
            "href": {
              "type": "string",
              "format": "uri"
            }
          },
          "required": [
            "label",
            "href"
          ],
          "additionalProperties": false
        },
        "cover": {
          "type": "string"
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "tier",
        "summary",
        "year"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}