# Cloudflare Pages / Netlify cache headers.
# GitHub Pages ignores this file — its own CDN handles caching.
#
# Astro emits content-hashed filenames into /_astro/, so those assets are
# safe to mark `immutable, max-age=1y`. Fonts, textures, badges, and cover
# images are committed once and never mutate. HTML stays short-cached so
# content edits propagate quickly without a manual purge.

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/textures/*
  Cache-Control: public, max-age=31536000, immutable

/badges/*
  Cache-Control: public, max-age=31536000, immutable

/covers/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=2592000

# HTML — short browser cache, longer CDN cache with revalidation.
# stale-while-revalidate keeps the CDN responsive during a deploy.
/*
  Cache-Control: public, max-age=300, s-maxage=3600, stale-while-revalidate=86400
