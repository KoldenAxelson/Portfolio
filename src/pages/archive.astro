---
// Static redirect. Archive content moved into /projects#archive. This page
// exists so anyone with an old bookmark still lands in the right place.
//
// Forkers: safe to delete entirely if you've never published an /archive page.
import { url } from '@lib/url';

const target = url('/projects') + '#archive';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Archive — moved</title>
    <link rel="canonical" href={target} />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <meta name="robots" content="noindex" />
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </head>
  <body>
    <p>The archive has moved to <a href={target}>/projects#archive</a>. Redirecting…</p>
  </body>
</html>
