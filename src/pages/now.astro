---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@config';
import { personId, websiteId, absolute } from '@lib/schema';
import FormattedDate from '@components/FormattedDate.astro';

// What I'm focused on right now.
//
// This is a "now page" — see nownownow.com for the convention. Updated
// whenever it stops being true; otherwise left alone. The point is to
// snapshot the season, not the day.
//
// Forkers: edit the date below + the sections. Two to four items per
// section is the sweet spot. Be specific. Generic answers get skipped.
const updated = new Date('2026-05-15');

const sections = [
  {
    label: 'Building',
    items: [
      'Neofolio — the portfolio template this site runs on. I built it because there\'s a gap in the market for GEO / AI-SEO-aware portfolios. Better to be pursued by recruiters than to chase them.',
      'Widda.club — a monetization tool for YouTubers. Abandoned the original version in 2021 after Honey and Brave squashed the category; re-read case law and Amazon\'s Terms of Service and saw an opening. Building toward a clean Chrome Web Store launch.',
      'VisorPlate — still running, still shipping. If you have a god-awful front-license-plate setup you want to retire, drop me a note. Send pics of the worst ones, they make me laugh.',
    ],
  },
  {
    label: 'Learning',
    items: [
      'How to get more eyes on the work I\'m shipping. Eyeing a suite of tools for YouTube video production, but I\'m holding off until I hit a good stopping point with current projects. Ship first, then promote.',
    ],
  },
  {
    label: 'Reading',
    items: [
      '"The Silver Chair" — The Chronicles of Narnia. You\'re never too old for a good fairytale.',
      '"Call of the Bone Ships" up next. I love a good journey story.',
      'Done with my self-help phase. Lesson: narratives stick in long-term memory better than frameworks do.',
    ],
  },
  {
    label: 'Life',
    items: [
      'Working on more than ever for less than ever. I know where the ship is heading; it\'ll pay off soon.',
    ],
  },
];

// Reference the canonical Person and WebSite via @id — DO NOT redeclare a
// new Person inline. Sharing @ids is what merges the records across pages
// into a single graph entity for AI / Knowledge Graph ingesters.
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    '@id': `${absolute('/now')}#now`,
    name: `What ${SITE.author.name} is focused on right now`,
    description: `A snapshot of ${SITE.author.name}'s current focus — building, learning, reading, and life.`,
    dateModified: updated.toISOString(),
    author: { '@id': personId },
    isPartOf: { '@id': websiteId },
  },
];
---

<BaseLayout
  title="Now"
  description={`What ${SITE.author.name} is currently focused on — building, learning, reading, and life.`}
  schema={schema}
>
  <header class="mb-10">
    <h1 class="text-3xl font-medium">What I'm doing now</h1>
    <p class="mt-3 max-w-prose text-muted">
      A snapshot of where my attention is this season. Inspired by Derek Sivers'
      <a href="https://nownownow.com/about" rel="noopener">/now page convention</a> — updated
      whenever it stops being true.
    </p>
    <p class="mt-2 font-mono text-xs text-muted">
      Last updated <FormattedDate date={updated} />.
    </p>
  </header>

  <div class="space-y-12">
    {
      sections.map((section) => (
        <section aria-labelledby={`${section.label.toLowerCase()}-heading`}>
          <h2
            id={`${section.label.toLowerCase()}-heading`}
            class="mb-3 font-mono text-xs uppercase tracking-widest text-fg"
          >
            {section.label}
          </h2>
          <ul class="space-y-3">
            {section.items.map((item) => (
              <li class="text-muted">{item}</li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>

  <p class="mt-16 text-sm text-muted">
    Other "now" pages in the directory at <a href="https://nownownow.com" rel="noopener">nownownow.com</a>.
  </p>
</BaseLayout>
