---
import BaseLayout from '@layouts/BaseLayout.astro';
import FormattedDate from '@components/FormattedDate.astro';

// The things on my machine right now.
//
// Schema:
//   caption  — short prose per category (1–3 sentences, always visible). Adds
//              context to the list. Omit if the list is self-explanatory.
//   items[].name   — required
//   items[].note   — short factual context (e.g. "shell", "learning")
//   items[].link   — canonical URL; turns the name into a link
//   items[].detail — longer prose, hidden behind a native <details> accordion.
//                    Content stays in the DOM regardless of open/closed state,
//                    so AI scrapers index it normally. Use sparingly — only
//                    when there's a genuine story or config worth sharing.
//
// Recruiters skim this page; AI scrapers index it as a list of tools. Keep
// captions tight and details opt-in. Editorial voice belongs on /articles.

type Item = { name: string; note?: string; link?: string; detail?: string };
type Category = { id: string; label: string; caption?: string; items: Item[] };

const updated = new Date('2026-05-15');

const stack: Category[] = [
  {
    id: 'editor',
    label: 'Editor',
    caption:
      'Three editors, three jobs. Zed runs the day, VS Code shows up when the lifting gets heavy, plain vim covers everything in between.',
    items: [
      { name: 'Zed', note: 'editor of choice', link: 'https://zed.dev' },
      {
        name: 'VS Code',
        note: 'when the work needs the heavier IDE',
        link: 'https://code.visualstudio.com',
      },
      {
        name: 'Vim',
        note: 'plain vim — not neovim',
        link: 'https://www.vim.org',
        detail:
          "Four years of government work in environments where neovim wasn't an option made bare vi(m) native. Now it's where 90% of my quick edits live — no plugins, no dotfiles, just whatever's already on the box.",
      },
    ],
  },
  {
    id: 'terminal',
    label: 'Terminal',
    caption: 'Default zsh with Oh My Zsh. Basic, lovely, gets out of the way.',
    items: [{ name: 'Oh My Zsh', link: 'https://ohmyz.sh' }],
  },
  {
    id: 'languages',
    label: 'Languages',
    caption: 'Seven I reach for. Each one earned the slot for a different reason.',
    items: [
      { name: 'Go', note: 'what I think in' },
      { name: 'Rust', note: 'in an ongoing debate with the compiler' },
      { name: 'Python', note: "there's a library for everything" },
      { name: 'TypeScript', note: 'unavoidable, but needed' },
      { name: 'Tailwind', note: 'the tool for modern web design' },
      { name: 'PHP', note: 'mostly for Laravel' },
      { name: 'SQL', note: 'enough to make Postgres my full stack' },
    ],
  },
  {
    id: 'frameworks',
    label: 'Frameworks',
    caption:
      'Where the work happens. There are others I touch; these are the ones I keep coming back to.',
    items: [
      { name: 'Astro', link: 'https://astro.build' },
      { name: 'Vue', link: 'https://vuejs.org' },
      { name: 'FastAPI', link: 'https://fastapi.tiangolo.com' },
      { name: 'Laravel', link: 'https://laravel.com' },
    ],
  },
  {
    id: 'cloud',
    label: 'Cloud',
    caption: 'Cloudflare won me over fast. AWS is the muscle memory from years of DevOps.',
    items: [
      { name: 'Cloudflare', note: 'I love this so much', link: 'https://cloudflare.com' },
      { name: 'AWS', note: 'my comfort zone', link: 'https://aws.amazon.com' },
    ],
  },
  {
    id: 'data',
    label: 'Database',
    caption: 'Default to Postgres. Justify everything else.',
    items: [
      {
        name: 'Postgres',
        note: "for serious projects (and for things that aren't serious)",
        link: 'https://postgresql.org',
      },
      {
        name: 'SQLite',
        note: 'when you absolutely know Postgres is a bad idea',
        link: 'https://sqlite.org',
      },
      {
        name: 'Redis',
        note: 'replaceable by Postgres, but worth the time saved',
        link: 'https://redis.io',
      },
    ],
  },
  {
    id: 'cli',
    label: 'CLI',
    caption: 'Four daily. brew is the one getting away from me.',
    items: [
      { name: 'git', note: 'like every developer', link: 'https://git-scm.com' },
      { name: 'gh', note: "debating leaving this but it's free", link: 'https://cli.github.com' },
      {
        name: 'wrangler',
        note: 'loving this more by the day',
        link: 'https://developers.cloudflare.com/workers/wrangler',
      },
      { name: 'brew', note: 'too many caskets', link: 'https://brew.sh' },
    ],
  },
  {
    id: 'hardware',
    label: 'Hardware',
    caption: 'Apple ecosystem mostly. One paper notebook running the rest.',
    items: [
      { name: 'Mac M2 Mini' },
      { name: 'Alienware monitor', note: '27"' },
      { name: 'Apple Magic Keyboard' },
      { name: 'Apple Magic Trackpad' },
      { name: 'Analogue notebook', note: 'runs my life' },
    ],
  },
];
---

<BaseLayout
  title="Uses"
  description="The stack, tools, and hardware I actually use, with notes on why."
>
  <header class="mb-12">
    <h1 class="text-3xl font-medium">Uses</h1>
    <p class="mt-3 max-w-prose text-muted">
      The things on my machine right now, and what I'd say about them if you asked.
      Inspired by <a href="https://uses.tech">uses.tech</a>.
    </p>
    <p class="mt-3 font-mono text-xs text-muted">
      Last updated <FormattedDate date={updated} />.
    </p>
  </header>

  <div class="space-y-6">
    {
      stack.map((category) => (
        <details
          id={category.id}
          class="group/cat scroll-mt-24 border-b border-border/60 pb-6 last:border-b-0"
        >
          <summary
            class="flex cursor-pointer list-none items-center justify-between gap-3 py-1 [&::-webkit-details-marker]:hidden"
            aria-labelledby={`${category.id}-heading`}
          >
            <h2
              id={`${category.id}-heading`}
              class="font-mono text-xs uppercase tracking-widest text-fg transition-colors group-hover/cat:!text-accent"
            >
              {category.label}
            </h2>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="h-4 w-4 shrink-0 text-muted transition-transform duration-200 group-open/cat:rotate-90 group-hover/cat:!text-accent"
            >
              <path d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          </summary>

          <div class="mt-4">
            {category.caption && (
              <p class="mb-5 max-w-prose text-sm leading-relaxed text-muted">{category.caption}</p>
            )}

            <ul class="-mx-2 space-y-0.5">
              {category.items.map((item) => {
                const head = (
                  <span class="text-fg">
                    {item.link ? (
                      <a
                        href={item.link}
                        rel="noopener"
                        class="font-medium no-underline hover:!text-accent"
                      >
                        {item.name}
                      </a>
                    ) : (
                      <span class="font-medium">{item.name}</span>
                    )}
                    {item.note && <span class="text-muted"> · {item.note}</span>}
                  </span>
                );

                return (
                  <li>
                    {item.detail ? (
                      <details class="group/item rounded px-2 py-1 transition-colors hover:bg-border/30">
                        <summary class="flex cursor-pointer list-none items-center gap-3 [&::-webkit-details-marker]:hidden">
                          {head}
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                            class="ml-auto h-4 w-4 shrink-0 text-muted/70 transition-transform duration-200 group-open/item:rotate-90"
                          >
                            <path d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                          </svg>
                        </summary>
                        <p class="mt-2 max-w-prose text-sm leading-relaxed text-muted">
                          {item.detail}
                        </p>
                      </details>
                    ) : (
                      <div class="px-2 py-1">{head}</div>
                    )}
                  </li>
                );
              })}
            </ul>
          </div>
        </details>
      ))
    }
  </div>

</BaseLayout>

<script is:inline>
  // When a visitor lands at /uses#hardware (or any category anchor), make
  // sure that category's <details> is open so they see the content they
  // came for. Without this, a collapsed category would silently hide
  // anchor-targeted content.
  (function () {
    function openTargeted() {
      const id = window.location.hash.slice(1);
      if (!id) return;
      const el = document.getElementById(id);
      if (el && el.tagName.toLowerCase() === 'details') {
        el.open = true;
      }
    }
    window.addEventListener('hashchange', openTargeted);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', openTargeted);
    } else {
      openTargeted();
    }
  })();
</script>
