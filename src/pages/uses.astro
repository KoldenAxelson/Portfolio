---
import BaseLayout from '@layouts/BaseLayout.astro';
import FormattedDate from '@components/FormattedDate.astro';

// The things on my machine right now.
//
// Schema:
//   caption  — short prose per category (1–3 sentences, always visible). Adds
//              context to the list. Omit if the list is self-explanatory.
//   items[].name   — required
//   items[].note   — short factual context (e.g. "shell", "learning")
//   items[].link   — canonical URL; turns the name into a link
//   items[].detail — longer prose, hidden behind a native <details> accordion.
//                    Content stays in the DOM regardless of open/closed state,
//                    so AI scrapers index it normally. Use sparingly — only
//                    when there's a genuine story or config worth sharing.
//
// Recruiters skim this page; AI scrapers index it as a list of tools. Keep
// captions tight and details opt-in. Editorial voice belongs on /articles.

type Item = { name: string; note?: string; link?: string; detail?: string };
type Category = { id: string; label: string; caption?: string; items: Item[] };

const updated = new Date('2026-04-15');

const stack: Category[] = [
  {
    id: 'editor',
    label: 'Editor',
    caption:
      "Spent ten years bouncing between editors. Modal editing won; LazyVim's batteries-included setup spared me another six months of yak-shaving my own config.",
    items: [
      {
        name: 'Neovim',
        note: 'LazyVim distribution',
        link: 'https://neovim.io',
        detail:
          "Bound to caps lock. About 600 lines of Lua on top of LazyVim — mostly LSP wiring, a handful of keymaps that ate Vimium's lunch, and a treesitter playground I refuse to remove. Configs versioned in dotfiles.",
      },
      {
        name: 'VS Code',
        note: 'pair-programming only',
        link: 'https://code.visualstudio.com',
        detail:
          'Stays installed because Live Share is unmatched for synchronous pair-programming. Otherwise dormant — open it maybe twice a month.',
      },
    ],
  },
  {
    id: 'terminal',
    label: 'Terminal',
    caption:
      'Ghostty replaced Alacritty mid-2025 — same speed, less config friction. Everything else is rote: fish for ergonomics, tmux for sessions that outlive the SSH connection.',
    items: [
      {
        name: 'Ghostty',
        link: 'https://ghostty.org',
        detail:
          "Switched from Alacritty when I needed proper accessibility support and tabs that don't lag. The Mitchell-Hashimoto pedigree helped, but it earned the slot on merit.",
      },
      { name: 'fish', note: 'shell', link: 'https://fishshell.com' },
      { name: 'tmux', note: 'long-running sessions', link: 'https://github.com/tmux/tmux' },
      { name: 'starship', note: 'prompt', link: 'https://starship.rs' },
    ],
  },
  {
    id: 'languages',
    label: 'Languages',
    caption:
      'Five years of Python, four of Go, three of TypeScript — in that order. Rust is the slow burn; reading more than writing for now.',
    items: [
      { name: 'TypeScript' },
      { name: 'Go' },
      { name: 'Python' },
      {
        name: 'Rust',
        note: 'learning',
        detail:
          'Working through "Programming Rust" (2nd ed) on weekends. Borrow checker still wins more arguments than I do; the patterns are starting to feel less like fighting the compiler and more like a conversation.',
      },
      { name: 'SQL', note: 'Postgres dialect' },
    ],
  },
  {
    id: 'frameworks',
    label: 'Frameworks',
    caption:
      'Astro for content-first sites, SvelteKit for app-shaped things, FastAPI for backend prototypes. The common thread is ship-by-default with an escape hatch when you need it.',
    items: [
      { name: 'Astro', link: 'https://astro.build' },
      { name: 'Vue', link: 'https://vuejs.org' },
      { name: 'SvelteKit', link: 'https://kit.svelte.dev' },
      { name: 'FastAPI', link: 'https://fastapi.tiangolo.com' },
      { name: 'Echo', note: 'Go web framework', link: 'https://echo.labstack.com' },
    ],
  },
  {
    id: 'cloud',
    label: 'Cloud',
    caption:
      'Cloudflare is the default for anything serverless. AWS Lightsail handles the few workloads that genuinely need a long-running process. Fly.io for the rare regional-edge case.',
    items: [
      {
        name: 'Cloudflare',
        note: 'Pages, Workers, R2, D1',
        link: 'https://cloudflare.com',
        detail:
          "Pages for static. Workers for the contact form and anything edge-y. R2 for blob storage that doesn't bleed me dry on egress. D1 for small projects where Postgres would be overkill.",
      },
      { name: 'AWS Lightsail', note: 'stateful workloads' },
      { name: 'Fly.io', note: 'regional edge', link: 'https://fly.io' },
    ],
  },
  {
    id: 'data',
    label: 'Database',
    caption:
      "Postgres unless there's a specific reason not to. SQLite for sidecars and embedded use. DuckDB has earned permanent residency in my analytics workflow.",
    items: [
      {
        name: 'Postgres',
        link: 'https://postgresql.org',
        detail:
          "Self-hosted on the bigger projects, Neon for prototypes, Supabase when I want auth bundled. The query planner is the single most useful thing to learn deeply if you do backend work — it's how I find the half of my mistakes that survive code review.",
      },
      { name: 'SQLite', note: 'embedded' },
      { name: 'Redis' },
      { name: 'DuckDB', note: 'analytics', link: 'https://duckdb.org' },
    ],
  },
  {
    id: 'cli',
    label: 'CLI',
    caption:
      "Most of these were brew installs from a Wes Bos talk in 2018 and never left. fzf is the best $0 upgrade most engineers haven't made yet.",
    items: [
      { name: 'gh', link: 'https://cli.github.com' },
      { name: 'wrangler', link: 'https://developers.cloudflare.com/workers/wrangler' },
      { name: 'jq', link: 'https://jqlang.github.io/jq' },
      {
        name: 'fzf',
        link: 'https://github.com/junegunn/fzf',
        detail:
          'Bound to ctrl-r for shell history, ctrl-t for file search, and a custom binding that fuzz-finds across my projects directory. Saved me probably 200 hours of tab-completion fatigue.',
      },
      { name: 'ripgrep', link: 'https://github.com/BurntSushi/ripgrep' },
      { name: 'fd', link: 'https://github.com/sharkdp/fd' },
      { name: 'eza', link: 'https://eza.rocks' },
    ],
  },
  {
    id: 'hardware',
    label: 'Hardware',
    caption:
      "M3 Pro after years of x86. The HHKB is the only piece of gear I've owned for over five years; I'd buy three if my keyboard travel changed.",
    items: [
      { name: 'MacBook Pro', note: 'M3 Pro, 36 GB' },
      { name: 'LG UltraFine 5K', note: '27"' },
      {
        name: 'HHKB Professional Hybrid',
        note: 'Type-S',
        detail:
          "Type-S silenced sliders, 60% layout. Two USB modes paired with my work iMac and personal Mac. Sublimely consistent feel after seven years. I've stopped trying to convince other people.",
      },
      { name: 'Logitech MX Master 3' },
    ],
  },
];
---

<BaseLayout
  title="Uses"
  description="The stack, tools, and hardware I actually use, with notes on why."
>
  <header class="mb-12">
    <h1 class="text-3xl font-medium">Uses</h1>
    <p class="mt-3 max-w-prose text-muted">
      The things on my machine right now, and what I'd say about them if you asked.
      Inspired by <a href="https://uses.tech">uses.tech</a>.
    </p>
    <p class="mt-3 font-mono text-xs text-muted">
      Last updated <FormattedDate date={updated} />.
    </p>
  </header>

  <div class="space-y-6">
    {
      stack.map((category) => (
        <details
          id={category.id}
          class="group/cat scroll-mt-24 border-b border-border/60 pb-6 last:border-b-0"
        >
          <summary
            class="flex cursor-pointer list-none items-center justify-between gap-3 py-1 [&::-webkit-details-marker]:hidden"
            aria-labelledby={`${category.id}-heading`}
          >
            <h2
              id={`${category.id}-heading`}
              class="font-mono text-xs uppercase tracking-widest text-fg transition-colors group-hover/cat:!text-accent"
            >
              {category.label}
            </h2>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="h-4 w-4 shrink-0 text-muted transition-transform duration-200 group-open/cat:rotate-90 group-hover/cat:!text-accent"
            >
              <path d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          </summary>

          <div class="mt-4">
            {category.caption && (
              <p class="mb-5 max-w-prose text-sm leading-relaxed text-muted">{category.caption}</p>
            )}

            <ul class="-mx-2 space-y-0.5">
              {category.items.map((item) => {
                const head = (
                  <span class="text-fg">
                    {item.link ? (
                      <a
                        href={item.link}
                        rel="noopener"
                        class="font-medium no-underline hover:!text-accent"
                      >
                        {item.name}
                      </a>
                    ) : (
                      <span class="font-medium">{item.name}</span>
                    )}
                    {item.note && <span class="text-muted"> · {item.note}</span>}
                  </span>
                );

                return (
                  <li>
                    {item.detail ? (
                      <details class="group/item rounded px-2 py-1 transition-colors hover:bg-border/30">
                        <summary class="flex cursor-pointer list-none items-center gap-3 [&::-webkit-details-marker]:hidden">
                          {head}
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                            class="ml-auto h-4 w-4 shrink-0 text-muted/70 transition-transform duration-200 group-open/item:rotate-90"
                          >
                            <path d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                          </svg>
                        </summary>
                        <p class="mt-2 max-w-prose text-sm leading-relaxed text-muted">
                          {item.detail}
                        </p>
                      </details>
                    ) : (
                      <div class="px-2 py-1">{head}</div>
                    )}
                  </li>
                );
              })}
            </ul>
          </div>
        </details>
      ))
    }
  </div>

</BaseLayout>

<script is:inline>
  // When a visitor lands at /uses#hardware (or any category anchor), make
  // sure that category's <details> is open so they see the content they
  // came for. Without this, a collapsed category would silently hide
  // anchor-targeted content.
  (function () {
    function openTargeted() {
      const id = window.location.hash.slice(1);
      if (!id) return;
      const el = document.getElementById(id);
      if (el && el.tagName.toLowerCase() === 'details') {
        el.open = true;
      }
    }
    window.addEventListener('hashchange', openTargeted);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', openTargeted);
    } else {
      openTargeted();
    }
  })();
</script>
