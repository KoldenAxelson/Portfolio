---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@config';
import { personId } from '@lib/schema';
import { experience, education, skills } from '@data/cv';

// Build a Person SUPPLEMENT — same @id as the canonical Person emitted by
// SEO.astro, so JSON-LD parsers merge the two records into a single entity.
// This block adds the heavy résumé-shaped properties (hasOccupation,
// alumniOf, knowsAbout) that we don't want on every page.
//
// hasOccupation is the property an AI looking at "what does this person do?"
// will key off of. Each role becomes an Occupation node with its own date
// range, so career history is structurally walkable, not buried in prose.
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': personId,
    hasOccupation: experience.map((job) => ({
      '@type': 'Occupation',
      name: job.role,
      occupationLocation: { '@type': 'Place', name: job.location },
      hiringOrganization: { '@type': 'Organization', name: job.employer },
      description: job.summary,
      ...(job.startDate && { startDate: job.startDate }),
      ...(job.endDate && { endDate: job.endDate }),
      skills: job.stack.join(', '),
      responsibilities: job.highlights,
    })),
    alumniOf: education.map((e) => ({
      '@type': 'EducationalOrganization',
      name: e.school,
      ...(e.notes && { description: `${e.degree} (${e.year}). ${e.notes}` }),
    })),
    worksFor: experience
      .filter((e) => e.end === 'present')
      .map((e) => ({ '@type': 'Organization', name: e.employer })),
    knowsAbout: Object.values(skills).flat(),
  },
];
---

<BaseLayout
  title="CV"
  description={`Full résumé and work history for ${SITE.author.name}.`}
  schema={schema}
>
  <header class="mb-8">
    <h1 class="text-3xl font-medium">CV</h1>
    <p class="mt-3 max-w-prose text-muted">
      Full work history, plain text. Print-friendly — Cmd-P from this page
      gives you a clean PDF.
    </p>
  </header>

  <section id="summary" class="mb-10 scroll-mt-24" aria-labelledby="summary-heading">
    <h2 id="summary-heading" class="mb-2 text-xl font-medium">Summary</h2>
    <p class="text-muted">{SITE.author.longBio}</p>
  </section>

  <section id="experience" class="mb-10 scroll-mt-24" aria-labelledby="experience-heading">
    <h2 id="experience-heading" class="mb-4 text-xl font-medium">Experience</h2>
    <ol class="space-y-8">
      {
        experience.map((job) => (
          <li>
            <header class="flex flex-wrap items-baseline justify-between gap-2">
              <h3 class="m-0 font-medium">
                {job.role} · <span class="text-muted">{job.employer}</span>
              </h3>
              <span class="font-mono text-xs text-muted">
                {job.start}–{job.end} · {job.location}
              </span>
            </header>
            <p class="mt-2 text-muted">{job.summary}</p>
            {job.highlights.length > 0 && (
              <ul class="mt-2 list-disc pl-5 text-sm">
                {job.highlights.map((h) => (
                  <li>{h}</li>
                ))}
              </ul>
            )}
            {job.stack.length > 0 && (
              <p class="mt-2 font-mono text-xs text-muted">stack: {job.stack.join(', ')}</p>
            )}
          </li>
        ))
      }
    </ol>
  </section>

  <section id="education" class="mb-10 scroll-mt-24" aria-labelledby="education-heading">
    <h2 id="education-heading" class="mb-4 text-xl font-medium">Education</h2>
    <ul class="space-y-3">
      {
        education.map((e) => (
          <li>
            <p class="font-medium">
              {e.degree} · <span class="text-muted">{e.school}</span>{' '}
              <span class="font-mono text-xs text-muted">({e.year})</span>
            </p>
            {e.notes && <p class="text-sm text-muted">{e.notes}</p>}
          </li>
        ))
      }
    </ul>
  </section>

  <section id="skills" class="mb-10 scroll-mt-24" aria-labelledby="skills-heading">
    <h2 id="skills-heading" class="mb-4 text-xl font-medium">Skills</h2>
    <dl class="grid grid-cols-1 gap-x-8 gap-y-3 sm:grid-cols-[max-content_1fr]">
      {
        Object.entries(skills).map(([cat, items]) => (
          <>
            <dt class="font-mono text-sm text-muted">{cat}</dt>
            <dd class="m-0">{items.join(', ')}</dd>
          </>
        ))
      }
    </dl>
  </section>
</BaseLayout>
