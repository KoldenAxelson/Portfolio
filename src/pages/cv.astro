---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import FormattedDate from '@components/FormattedDate.astro';
import { SITE } from '@config';
import { personId, credentialId } from '@lib/schema';
import { getBadgeImage, badgeImageObject, type BadgeImage } from '@lib/cert';
import { experience, education, skills } from '@data/cv';

// Pull every non-draft certificate so we can both render them on this page
// AND attach them to the Person schema as `hasCredential`. Most-recent first.
const certificates = (await getCollection('certificates', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.issueDate.valueOf() - a.data.issueDate.valueOf(),
);

// Resolve each cert's badge once so the JSON-LD ImageObject ships with
// pixel dimensions — same logic that powers /certificates.
//
// NOTE: data collections (YAML) expose `id` not `slug` — using `slug`
// here returns undefined and silently collapses every entry to the same
// Map key. The fix is to use `c.id` everywhere we touch a certificate.
const certBadges = new Map<string, BadgeImage | null>(
  await Promise.all(
    certificates.map(async (c) => [c.id, await getBadgeImage(c.data.badge)] as const),
  ),
);

// Build a Person SUPPLEMENT — same @id as the canonical Person emitted by
// SEO.astro, so JSON-LD parsers merge the two records into a single entity.
// This block adds the heavy résumé-shaped properties (hasOccupation,
// alumniOf, knowsAbout, hasCredential) that we don't want on every page.
//
// hasOccupation is the property an AI looking at "what does this person do?"
// will key off of. Each role becomes an Occupation node with its own date
// range, so career history is structurally walkable, not buried in prose.
//
// hasCredential closes the loop with the /certificates page: each entry is
// the same EducationalOccupationalCredential @id used there, so JSON-LD
// parsers merge the two records into a single graph entity. We include the
// FULL payload here (description, competencyRequired, etc.) — not just the
// minimum — because /cv is the page recruiters' AIs hit hardest, and we
// want each credential to be a complete graph node even if the AI never
// fetches /certificates.
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': personId,
    hasOccupation: experience.map((job) => ({
      '@type': 'Occupation',
      name: job.role,
      occupationLocation: { '@type': 'Place', name: job.location },
      hiringOrganization: { '@type': 'Organization', name: job.employer },
      description: job.summary,
      ...(job.startDate && { startDate: job.startDate }),
      ...(job.endDate && { endDate: job.endDate }),
      skills: job.stack.join(', '),
      responsibilities: job.highlights,
    })),
    alumniOf: education.map((e) => ({
      '@type': 'EducationalOrganization',
      name: e.school,
      ...(e.notes && { description: `${e.degree} (${e.year}). ${e.notes}` }),
    })),
    worksFor: experience
      .filter((e) => e.end === 'present')
      .map((e) => ({ '@type': 'Organization', name: e.employer })),
    knowsAbout: Object.values(skills).flat(),
    ...(certificates.length > 0 && {
      hasCredential: certificates.map((c) => {
        const image = badgeImageObject(certBadges.get(c.id) ?? null);
        return {
          '@type': 'EducationalOccupationalCredential',
          // Same @id as on /certificates so the two records merge.
          '@id': credentialId(c.id),
          name: c.data.name,
          ...(c.data.description && { description: c.data.description }),
          credentialCategory: 'Professional Certification',
          recognizedBy: {
            '@type': 'Organization',
            name: c.data.issuer,
            ...(c.data.issuerUrl && { url: c.data.issuerUrl }),
          },
          validFrom: c.data.issueDate.toISOString().slice(0, 10),
          ...(c.data.expirationDate && {
            validUntil: c.data.expirationDate.toISOString().slice(0, 10),
          }),
          ...(c.data.credentialId && { identifier: c.data.credentialId }),
          ...(c.data.verifyUrl && { url: c.data.verifyUrl }),
          ...(image && { image }),
          ...(c.data.skills.length > 0 && { competencyRequired: c.data.skills }),
        };
      }),
    }),
  },
];

const now = new Date();
const activeCertificates = certificates.filter(
  (c) => !c.data.expirationDate || c.data.expirationDate > now,
);

// Visible contact links for the header. Strip the URL scheme so ATS
// parsers and human readers both see "linkedin.com/in/..." — the most
// recognizable form. Skip any link the author left empty.
const visibleLinks: { label: string; href: string }[] = [];
if (SITE.links.github) {
  visibleLinks.push({
    label: SITE.links.github.replace(/^https?:\/\//, ''),
    href: SITE.links.github,
  });
}
if (SITE.links.linkedin) {
  visibleLinks.push({
    label: SITE.links.linkedin.replace(/^https?:\/\//, ''),
    href: SITE.links.linkedin,
  });
}

// Format an employment date range. Uses the ISO `startDate`/`endDate` from
// `cv.ts` when present (renders as "Jan 2024 – Present"); falls back to
// the year-only `start`/`end` fields when not. Month-precision is the ATS
// convention for employment ranges.
function jobDateRange(job: (typeof experience)[number]): string {
  const fmt = (iso: string) =>
    new Date(iso).toLocaleDateString(SITE.locale, { month: 'short', year: 'numeric' });
  const start = job.startDate ? fmt(job.startDate) : job.start;
  const end =
    job.end === 'present'
      ? 'Present'
      : job.endDate
        ? fmt(job.endDate)
        : job.end;
  return `${start} – ${end}`;
}

// Per-page toolbar — Print, PDF download, DOCX download. Rendered by
// TopNav as a center-justified row on lg+; behind the arrow-down-circle
// button next to the hamburger on mobile.
const cvTools = [
  { icon: 'printer', label: 'Print', action: 'print' as const },
  ...(SITE.author.resume.pdf
    ? [{ icon: 'pdf', label: 'PDF', href: SITE.author.resume.pdf, download: true }]
    : []),
  ...(SITE.author.resume.docx
    ? [{ icon: 'docx', label: 'DOCX', href: SITE.author.resume.docx, download: true }]
    : []),
];
---

<BaseLayout
  title="CV"
  description={`Full résumé and work history for ${SITE.author.name}.`}
  schema={schema}
  tools={cvTools}
>
  {/*
    Standard résumé contact block — name as the prominent H1, role one
    line below, then the contact line. ATS parsers take the first
    prominent text element as the candidate's name; structuring it this
    way (rather than a "CV" page title) is what makes the document
    machine-readable as a résumé.

    Every contact field is visible TEXT (not just an icon link) so ATS
    body-parsers can extract them: `name@domain.tld` for email,
    `linkedin.com/in/...` for profiles. Print preserves the block;
    the on-page toolbar (Print / PDF / DOCX) lives in TopNav and is
    hidden in print.
  */}
  <header class="mb-10 print:mb-6">
    <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">{SITE.author.name}</h1>
    <p class="mt-2 text-lg text-muted">{SITE.author.role}</p>
    <ul class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-sm text-muted">
      {SITE.author.location && <li>{SITE.author.location}</li>}
      <li>
        <a href={`mailto:${SITE.author.email}`} class="no-underline hover:!text-fg">
          {SITE.author.email}
        </a>
      </li>
      {SITE.author.phone && (
        <li>
          <a href={`tel:${SITE.author.phone.replace(/\s+/g, '')}`} class="no-underline hover:!text-fg">
            {SITE.author.phone}
          </a>
        </li>
      )}
      {visibleLinks.map((link) => (
        <li>
          <a href={link.href} rel="noopener" class="no-underline hover:!text-fg">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </header>

  <section id="summary" class="mb-10 scroll-mt-24" aria-labelledby="summary-heading">
    <h2 id="summary-heading" class="mb-2 text-xl font-medium">Summary</h2>
    <p class="text-muted">{SITE.author.longBio}</p>
  </section>

  <section id="experience" class="mb-10 scroll-mt-24" aria-labelledby="experience-heading">
    <h2 id="experience-heading" class="mb-4 text-xl font-medium">Experience</h2>
    <ol class="space-y-8">
      {
        /* `print:break-inside-avoid` on each role keeps a job from being
           split across two printed pages — much cleaner Cmd-P output. */
        experience.map((job) => (
          <li class="print:break-inside-avoid">
            <header class="flex flex-wrap items-baseline justify-between gap-2">
              <h3 class="m-0 font-medium">
                {job.role} · <span class="text-muted">{job.employer}</span>
              </h3>
              <span class="font-mono text-xs text-muted">
                {jobDateRange(job)} · {job.location}
              </span>
            </header>
            <p class="mt-2 text-muted">{job.summary}</p>
            {job.highlights.length > 0 && (
              <ul class="mt-2 list-disc pl-5 text-sm">
                {job.highlights.map((h) => (
                  <li>{h}</li>
                ))}
              </ul>
            )}
            {job.stack.length > 0 && (
              // "Technologies:" is the ATS-conventional cue word for parsing
              // a tools list under an employment entry. Capital T matters —
              // older ATS keyword-match on the exact label.
              <p class="mt-2 font-mono text-xs text-muted">Technologies: {job.stack.join(', ')}</p>
            )}
          </li>
        ))
      }
    </ol>
  </section>

  <section id="education" class="mb-10 scroll-mt-24" aria-labelledby="education-heading">
    <h2 id="education-heading" class="mb-4 text-xl font-medium">Education</h2>
    <ul class="space-y-3">
      {
        education.map((e) => (
          <li>
            <p class="font-medium">
              {e.degree} · <span class="text-muted">{e.school}</span>{' '}
              <span class="font-mono text-xs text-muted">({e.year})</span>
            </p>
            {e.notes && <p class="text-sm text-muted">{e.notes}</p>}
          </li>
        ))
      }
    </ul>
  </section>

  {
    activeCertificates.length > 0 && (
      <section
        id="certifications"
        class="mb-10 scroll-mt-24"
        aria-labelledby="certifications-heading"
      >
        <h2 id="certifications-heading" class="mb-4 text-xl font-medium">Certifications</h2>
        <ul class="space-y-3">
          {activeCertificates.map((c) => (
            <li class="print:break-inside-avoid">
              <p class="font-medium">
                {c.data.name} · <span class="text-muted">{c.data.issuer}</span>{' '}
                <span class="font-mono text-xs text-muted">
                  {'('}<FormattedDate date={c.data.issueDate} precision="month" />{c.data.expirationDate && (
                    <>{' – '}<FormattedDate date={c.data.expirationDate} precision="month" /></>
                  )}{')'}
                </span>
              </p>
              {c.data.skills.length > 0 && (
                <p class="text-sm text-muted">{c.data.skills.join(' · ')}</p>
              )}
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section id="skills" class="mb-10 scroll-mt-24" aria-labelledby="skills-heading">
    <h2 id="skills-heading" class="mb-4 text-xl font-medium">Skills</h2>
    {/*
      Plain `<p>Category: items, items, items</p>` lines instead of a
      `<dl>/<dt>/<dd>` tree — older ATS pipelines (some Workday configs,
      legacy Taleo deployments, defense-contractor parsers) misread
      definition lists as glossary entries rather than skill groupings.
      Per-line paragraphs are universally understood as "Skills section:
      category-then-list", whether the parser is from 2003 or 2024.
    */}
    <div class="space-y-2">
      {
        Object.entries(skills).map(([cat, items]) => (
          <p>
            <span class="font-mono text-sm text-muted">{cat}:</span>{' '}
            {items.join(', ')}
          </p>
        ))
      }
    </div>
  </section>
</BaseLayout>
