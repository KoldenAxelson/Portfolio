---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@config';

// Forkers: edit this data. Keep it as plain TypeScript objects — that way
// AI scrapers index it as structured text, not opaque rendered HTML.

const experience = [
  {
    role: 'Senior Software Engineer',
    employer: 'Example Corp',
    location: 'Remote',
    start: '2023',
    end: 'present',
    summary:
      'Lead engineer on the platform team. Designed the multi-region failover system that now handles 12M requests/day.',
    highlights: [
      'Migrated billing pipeline from monolith to event-driven Kafka topology — cut p99 latency 70%.',
      'Owned hiring for the team; closed 4 engineers in 9 months.',
    ],
    stack: ['Go', 'Kafka', 'Postgres', 'AWS'],
  },
  {
    role: 'Software Engineer',
    employer: 'Previous Co',
    location: 'Hybrid · Boston, MA',
    start: '2020',
    end: '2023',
    summary:
      'Backend engineer on the data ingest team. Owned the schema-evolution layer and the customer-facing event-replay tooling.',
    highlights: [
      'Designed schema-registry-backed contract testing system that prevented 6 production incidents.',
      'Rewrote ingest worker pool — 3× throughput on same hardware.',
    ],
    stack: ['Python', 'Postgres', 'Redis', 'Terraform'],
  },
  // Add a DoD / classified entry if applicable. Carefully framed per STRATEGY.
  // {
  //   role: 'Systems Engineer (Cleared)',
  //   employer: 'Defense contractor',
  //   location: 'On-site, SCIF',
  //   start: '2016',
  //   end: '2020',
  //   summary: 'Five years building auditable, failure-tolerant systems under formal constraints. Details on request.',
  //   highlights: [
  //     'Order-of-magnitude scale: <X> users, <Y> requests/day, <Z>-nines uptime requirement.',
  //     'Worked under formal change-control and security-classification regimes.',
  //   ],
  //   stack: ['(details on request)'],
  // },
];

const education = [
  {
    school: 'State University',
    degree: 'B.S. Computer Science',
    year: '2016',
    notes: 'Honors thesis on distributed consensus protocols.',
  },
];

const skills = {
  Languages: ['TypeScript', 'Go', 'Python', 'SQL', 'Bash'],
  'Systems & Infra': [
    'Distributed systems',
    'Event-driven architecture',
    'Postgres internals',
    'Kafka',
    'Kubernetes',
  ],
  Cloud: ['AWS', 'Cloudflare', 'Terraform'],
  Practices: ['Code review', 'Hiring', 'Mentorship', 'Incident response'],
};

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: SITE.author.name,
    jobTitle: experience[0]?.role ?? SITE.author.role,
    email: `mailto:${SITE.author.email}`,
    url: SITE.url,
    alumniOf: education.map((e) => ({ '@type': 'EducationalOrganization', name: e.school })),
    worksFor: experience.slice(0, 1).map((e) => ({ '@type': 'Organization', name: e.employer })),
    knowsAbout: Object.values(skills).flat(),
  },
];
---

<BaseLayout
  title="CV"
  description={`Full résumé and work history for ${SITE.author.name}.`}
  schema={schema}
>
  <header class="mb-8">
    <h1 class="text-3xl font-medium">CV</h1>
    <p class="mt-3 max-w-prose text-muted">
      Full work history, plain text. Print-friendly. A PDF export is generated by
      <code>scripts/cv-pdf.sh</code> — see HUMAN.md.
    </p>
  </header>

  <section class="mb-10" aria-labelledby="summary">
    <h2 id="summary" class="mb-2 text-xl font-medium">Summary</h2>
    <p class="text-muted">{SITE.author.longBio}</p>
  </section>

  <section class="mb-10" aria-labelledby="exp">
    <h2 id="exp" class="mb-4 text-xl font-medium">Experience</h2>
    <ol class="space-y-8">
      {
        experience.map((job) => (
          <li>
            <header class="flex flex-wrap items-baseline justify-between gap-2">
              <h3 class="m-0 font-medium">
                {job.role} · <span class="text-muted">{job.employer}</span>
              </h3>
              <span class="font-mono text-xs text-muted">
                {job.start}–{job.end} · {job.location}
              </span>
            </header>
            <p class="mt-2 text-muted">{job.summary}</p>
            {job.highlights.length > 0 && (
              <ul class="mt-2 list-disc pl-5 text-sm">
                {job.highlights.map((h) => (
                  <li>{h}</li>
                ))}
              </ul>
            )}
            {job.stack.length > 0 && (
              <p class="mt-2 font-mono text-xs text-muted">stack: {job.stack.join(', ')}</p>
            )}
          </li>
        ))
      }
    </ol>
  </section>

  <section class="mb-10" aria-labelledby="edu">
    <h2 id="edu" class="mb-4 text-xl font-medium">Education</h2>
    <ul class="space-y-3">
      {
        education.map((e) => (
          <li>
            <p class="font-medium">
              {e.degree} · <span class="text-muted">{e.school}</span>{' '}
              <span class="font-mono text-xs text-muted">({e.year})</span>
            </p>
            {e.notes && <p class="text-sm text-muted">{e.notes}</p>}
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mb-10" aria-labelledby="skills">
    <h2 id="skills" class="mb-4 text-xl font-medium">Skills</h2>
    <dl class="grid grid-cols-1 gap-x-8 gap-y-3 sm:grid-cols-[max-content_1fr]">
      {
        Object.entries(skills).map(([cat, items]) => (
          <>
            <dt class="font-mono text-sm text-muted">{cat}</dt>
            <dd class="m-0">{items.join(', ')}</dd>
          </>
        ))
      }
    </dl>
  </section>
</BaseLayout>
