---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import FormattedDate from '@components/FormattedDate.astro';
import { SITE } from '@config';
import { personId } from '@lib/schema';
import { experience, education, skills } from '@data/cv';

// Pull every non-draft certificate so we can both render them on this page
// AND attach them to the Person schema as `hasCredential`. Most-recent first.
const certificates = (await getCollection('certificates', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.issueDate.valueOf() - a.data.issueDate.valueOf(),
);

// Build a Person SUPPLEMENT — same @id as the canonical Person emitted by
// SEO.astro, so JSON-LD parsers merge the two records into a single entity.
// This block adds the heavy résumé-shaped properties (hasOccupation,
// alumniOf, knowsAbout, hasCredential) that we don't want on every page.
//
// hasOccupation is the property an AI looking at "what does this person do?"
// will key off of. Each role becomes an Occupation node with its own date
// range, so career history is structurally walkable, not buried in prose.
//
// hasCredential closes the loop with the /certificates page: each entry is
// the same EducationalOccupationalCredential @id used there, so an AI graph
// walking from the Person can follow `hasCredential` to the credentials,
// and walking from the credentials page can follow `about` back to the
// Person — without duplicate or conflicting records.
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': personId,
    hasOccupation: experience.map((job) => ({
      '@type': 'Occupation',
      name: job.role,
      occupationLocation: { '@type': 'Place', name: job.location },
      hiringOrganization: { '@type': 'Organization', name: job.employer },
      description: job.summary,
      ...(job.startDate && { startDate: job.startDate }),
      ...(job.endDate && { endDate: job.endDate }),
      skills: job.stack.join(', '),
      responsibilities: job.highlights,
    })),
    alumniOf: education.map((e) => ({
      '@type': 'EducationalOrganization',
      name: e.school,
      ...(e.notes && { description: `${e.degree} (${e.year}). ${e.notes}` }),
    })),
    worksFor: experience
      .filter((e) => e.end === 'present')
      .map((e) => ({ '@type': 'Organization', name: e.employer })),
    knowsAbout: Object.values(skills).flat(),
    ...(certificates.length > 0 && {
      hasCredential: certificates.map((c) => ({
        '@type': 'EducationalOccupationalCredential',
        // Same @id as on /certificates so the two records merge.
        '@id': new URL(`/certificates#${c.slug}`, SITE.url).toString(),
        name: c.data.name,
        credentialCategory: 'Professional Certification',
        recognizedBy: {
          '@type': 'Organization',
          name: c.data.issuer,
          ...(c.data.issuerUrl && { url: c.data.issuerUrl }),
        },
        validFrom: c.data.issueDate.toISOString().slice(0, 10),
        ...(c.data.expirationDate && {
          validUntil: c.data.expirationDate.toISOString().slice(0, 10),
        }),
        ...(c.data.verifyUrl && { url: c.data.verifyUrl }),
      })),
    }),
  },
];

const now = new Date();
const activeCertificates = certificates.filter(
  (c) => !c.data.expirationDate || c.data.expirationDate > now,
);
---

<BaseLayout
  title="CV"
  description={`Full résumé and work history for ${SITE.author.name}.`}
  schema={schema}
>
  {/* On-screen only: the "CV" page title and the meta-instruction about
      printing are both hidden in print output. The page leads with the
      Summary section in print, which is the right thing for a printed CV. */}
  <header class="mb-8 print:hidden">
    <h1 class="text-3xl font-medium">CV</h1>
    <p class="mt-3 max-w-prose text-muted">
      Full work history, plain text. Print-friendly — Cmd-P from this page
      gives you a clean PDF.
    </p>
  </header>

  <section id="summary" class="mb-10 scroll-mt-24" aria-labelledby="summary-heading">
    <h2 id="summary-heading" class="mb-2 text-xl font-medium">Summary</h2>
    <p class="text-muted">{SITE.author.longBio}</p>
  </section>

  <section id="experience" class="mb-10 scroll-mt-24" aria-labelledby="experience-heading">
    <h2 id="experience-heading" class="mb-4 text-xl font-medium">Experience</h2>
    <ol class="space-y-8">
      {
        /* `print:break-inside-avoid` on each role keeps a job from being
           split across two printed pages — much cleaner Cmd-P output. */
        experience.map((job) => (
          <li class="print:break-inside-avoid">
            <header class="flex flex-wrap items-baseline justify-between gap-2">
              <h3 class="m-0 font-medium">
                {job.role} · <span class="text-muted">{job.employer}</span>
              </h3>
              <span class="font-mono text-xs text-muted">
                {job.start}–{job.end} · {job.location}
              </span>
            </header>
            <p class="mt-2 text-muted">{job.summary}</p>
            {job.highlights.length > 0 && (
              <ul class="mt-2 list-disc pl-5 text-sm">
                {job.highlights.map((h) => (
                  <li>{h}</li>
                ))}
              </ul>
            )}
            {job.stack.length > 0 && (
              <p class="mt-2 font-mono text-xs text-muted">stack: {job.stack.join(', ')}</p>
            )}
          </li>
        ))
      }
    </ol>
  </section>

  <section id="education" class="mb-10 scroll-mt-24" aria-labelledby="education-heading">
    <h2 id="education-heading" class="mb-4 text-xl font-medium">Education</h2>
    <ul class="space-y-3">
      {
        education.map((e) => (
          <li>
            <p class="font-medium">
              {e.degree} · <span class="text-muted">{e.school}</span>{' '}
              <span class="font-mono text-xs text-muted">({e.year})</span>
            </p>
            {e.notes && <p class="text-sm text-muted">{e.notes}</p>}
          </li>
        ))
      }
    </ul>
  </section>

  {
    activeCertificates.length > 0 && (
      <section
        id="certifications"
        class="mb-10 scroll-mt-24"
        aria-labelledby="certifications-heading"
      >
        <h2 id="certifications-heading" class="mb-4 text-xl font-medium">Certifications</h2>
        <ul class="space-y-3">
          {activeCertificates.map((c) => (
            <li class="print:break-inside-avoid">
              <p class="font-medium">
                {c.data.name} · <span class="text-muted">{c.data.issuer}</span>{' '}
                <span class="font-mono text-xs text-muted">
                  (<FormattedDate date={c.data.issueDate} />
                  {c.data.expirationDate && (
                    <>
                      {' – '}
                      <FormattedDate date={c.data.expirationDate} />
                    </>
                  )}
                  )
                </span>
              </p>
              {c.data.skills.length > 0 && (
                <p class="text-sm text-muted">{c.data.skills.join(' · ')}</p>
              )}
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section id="skills" class="mb-10 scroll-mt-24" aria-labelledby="skills-heading">
    <h2 id="skills-heading" class="mb-4 text-xl font-medium">Skills</h2>
    <dl class="grid grid-cols-1 gap-x-8 gap-y-3 sm:grid-cols-[max-content_1fr]">
      {
        Object.entries(skills).map(([cat, items]) => (
          <>
            <dt class="font-mono text-sm text-muted">{cat}</dt>
            <dd class="m-0">{items.join(', ')}</dd>
          </>
        ))
      }
    </dl>
  </section>
</BaseLayout>
