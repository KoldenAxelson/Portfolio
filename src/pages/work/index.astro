---
// /work has been renamed to /projects. This stub serves a static redirect so
// any existing bookmark or external link still works. Safe to delete the
// whole `src/pages/work/` directory once you're confident nobody's linking
// to the old URL.
import { url } from '@lib/url';
const target = url('/projects');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Projects — moved</title>
    <link rel="canonical" href={target} />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <meta name="robots" content="noindex" />
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </head>
  <body>
    <p>This page has moved to <a href={target}>/projects</a>. Redirecting…</p>
  </body>
</html>
