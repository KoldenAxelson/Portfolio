---
// /work/[slug] redirects to /projects/[slug]. Per-slug static redirect.
// Safe to delete this whole directory once no inbound links use the old URL.
import { getCollection } from 'astro:content';
import { url } from '@lib/url';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft && data.tier === 1);
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const target = url(`/projects/${slug}`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Project — moved</title>
    <link rel="canonical" href={target} />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <meta name="robots" content="noindex" />
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </head>
  <body>
    <p>This page has moved to <a href={target}>{target}</a>. Redirecting…</p>
  </body>
</html>
