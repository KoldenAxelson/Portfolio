---
// /writing has been renamed to /articles. Static redirect.
// Safe to delete this directory once no inbound links use the old URL.
import { url } from '@lib/url';
const target = url('/articles');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Articles — moved</title>
    <link rel="canonical" href={target} />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <meta name="robots" content="noindex" />
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </head>
  <body>
    <p>This page has moved to <a href={target}>/articles</a>. Redirecting…</p>
  </body>
</html>
