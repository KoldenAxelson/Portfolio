---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import FormattedDate from '@components/FormattedDate.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Writing" description="Essays on software, systems, and AI-age portfolio design.">
  <header class="mb-8">
    <h1 class="text-3xl font-medium">Writing</h1>
    <p class="mt-3 max-w-prose text-muted">
      Essays on software, systems, and AI-age portfolio design. Canonical home for everything I
      publish — syndicated elsewhere with <code>rel="canonical"</code> back here.
    </p>
  </header>

  <ul class="divide-y divide-border">
    {
      posts.map((post) => (
        <li class="py-4">
          <article>
            <h2 class="m-0 text-lg font-medium">
              <a href={`/writing/${post.slug}`} class="no-underline">
                {post.data.title}
              </a>
            </h2>
            <p class="mt-1 text-muted">{post.data.description}</p>
            <p class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs text-muted">
              <FormattedDate date={post.data.pubDate} />
              {post.data.tags.length > 0 && <span>· {post.data.tags.join(', ')}</span>}
            </p>
          </article>
        </li>
      ))
    }
  </ul>
</BaseLayout>
