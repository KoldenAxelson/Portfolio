---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import CertRow from '@components/CertRow.astro';
import { SITE } from '@config';
import { url } from '@lib/url';
import { getBadgeImage, badgeImageObject, type BadgeImage } from '@lib/cert';

// Most-recent first. Drafts excluded from the build.
const all = (await getCollection('certificates', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.issueDate.valueOf() - a.data.issueDate.valueOf(),
);

// Resolve every cert's badge ONCE at build time — Sharp reads the actual
// pixel dimensions so we can emit them on both the <img> tag (eliminates
// CLS) and in the JSON-LD ImageObject (better SEO/AI ingestion).
//
// NOTE: data collections expose `id` not `slug` — every key here is `c.id`.
const badges = new Map<string, BadgeImage | null>(
  await Promise.all(
    all.map(async (c) => [c.id, await getBadgeImage(c.data.badge)] as const),
  ),
);

const now = new Date();
const active = all.filter((c) => !c.data.expirationDate || c.data.expirationDate > now);
const expired = all.filter((c) => c.data.expirationDate && c.data.expirationDate <= now);

// ---------------------------------------------------------------------------
// JSON-LD: emit each credential as a schema.org EducationalOccupationalCredential,
// wrapped in an ItemList so a crawler can iterate the page as a structured set.
// Each credential's `@id` matches the one used on /cv (in Person.hasCredential),
// so JSON-LD parsers merge the two records into a single graph entity. The
// Person→Credential relationship lives on /cv (via hasCredential) — we don't
// need a back-reference from the credential here; @id sharing handles that.
// ---------------------------------------------------------------------------

function credentialSchema(c: (typeof all)[number]) {
  const d = c.data;
  const image = badgeImageObject(badges.get(c.id) ?? null);
  return {
    '@type': 'EducationalOccupationalCredential',
    '@id': new URL(`/certificates#${c.id}`, SITE.url).toString(),
    name: d.name,
    ...(d.description && { description: d.description }),
    credentialCategory: 'Professional Certification',
    recognizedBy: {
      '@type': 'Organization',
      name: d.issuer,
      ...(d.issuerUrl && { url: d.issuerUrl }),
    },
    validFrom: d.issueDate.toISOString().slice(0, 10),
    ...(d.expirationDate && { validUntil: d.expirationDate.toISOString().slice(0, 10) }),
    ...(d.credentialId && { identifier: d.credentialId }),
    ...(d.verifyUrl && { url: d.verifyUrl }),
    ...(image && { image }),
    ...(d.skills.length > 0 && { competencyRequired: d.skills }),
  };
}

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    '@id': new URL('/certificates#list', SITE.url).toString(),
    name: 'Certifications',
    numberOfItems: all.length,
    itemListOrder: 'https://schema.org/ItemListOrderDescending',
    itemListElement: all.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: credentialSchema(c),
    })),
  },
];

---

<BaseLayout
  title="Certifications"
  description={`Professional certifications and credentials held by ${SITE.author.name}, with verification links and skills covered.`}
  schema={schema}
>
  <header class="mb-8 print:hidden">
    <h1 class="text-3xl font-medium">Certifications</h1>
    <p class="mt-3 max-w-prose text-muted">
      Professional credentials I hold or have held. Each one links to its issuer's verification
      page so anyone can confirm authenticity directly. Expired credentials are kept on the page
      — letting them roll off without acknowledgement is a small dishonesty I'd rather not commit.
    </p>
  </header>

  {/*
    Checklist-row layout — same shape as the homepage Certificates section
    so the visual idiom is consistent. Badge (or trophy fallback) on the
    left, cert name + issuer + dates stacked on the right. Whole row links
    to the issuer's verify page when present; falls back to plain text
    when not (no self-link). Description, skills, and credential ID are
    intentionally omitted from the visible UI — they're still emitted into
    the JSON-LD for SEO/AI ingestion. Print-friendly via break-inside-avoid.
  */}
  {
    active.length > 0 && (
      <section id="active" class="mb-12 scroll-mt-24" aria-labelledby="active-heading">
        <h2 id="active-heading" class="mb-4 text-xl font-medium">Active</h2>
        <ul class="divide-y divide-border">
          {active.map((c) => (
            <li class="print:break-inside-avoid">
              <CertRow c={c} badge={badges.get(c.id) ?? null} />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    expired.length > 0 && (
      <section id="expired" class="scroll-mt-24" aria-labelledby="expired-heading">
        <h2 id="expired-heading" class="mb-2 text-xl font-medium">Expired</h2>
        <p class="mb-6 max-w-prose text-sm text-muted">
          Credentials that have lapsed. Kept here for an honest record — what I learned for them
          didn't expire even if the badge did.
        </p>
        <ul class="divide-y divide-border">
          {expired.map((c) => (
            <li class="print:break-inside-avoid">
              <CertRow c={c} badge={badges.get(c.id) ?? null} />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    all.length === 0 && (
      <p class="text-muted">
        No certifications listed yet. Add one by dropping a YAML file into
        <code>src/content/certificates/</code> — see <a href={url('/articles')}>docs</a>.
      </p>
    )
  }
</BaseLayout>
