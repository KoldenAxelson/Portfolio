---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import NetworkPanel from '@components/NetworkPanel.vue';
import { SITE } from '@config';

const entries = (await getCollection('network')).sort(
  (a, b) => (a.data.order ?? 100) - (b.data.order ?? 100) || a.data.name.localeCompare(b.data.name),
);

// Shape data for the Vue island. id = slug-ified file id.
const contacts = entries.map((e) => ({
  id: e.id.replace(/\.[^.]+$/, ''),
  name: e.data.name,
  title: e.data.title,
  company: e.data.company,
  blurb: e.data.blurb,
  relationship: e.data.relationship,
  link: e.data.link,
}));

const owner = {
  name: SITE.author.name,
  title: SITE.author.role,
  email: SITE.author.email,
  bio: SITE.author.longBio,
};

// JSON-LD: each connection as a related Person, the page as an ItemList.
// Helps AI scrapers understand "this is a network/connections page" rather
// than a generic content list.
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `${SITE.author.name}'s professional network`,
    itemListElement: contacts.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Person',
        name: c.name,
        jobTitle: c.title,
        ...(c.company && { worksFor: { '@type': 'Organization', name: c.company } }),
        ...(c.link && { url: c.link }),
        description: c.blurb,
      },
    })),
  },
];
---

<BaseLayout
  title="Network"
  description="People I'd vouch for — and would happily make an introduction to."
  schema={schema}
  wide
>
  <header class="mb-10">
    <h1 class="text-3xl font-medium">Network</h1>
  </header>

  <NetworkPanel client:load owner={owner} contacts={contacts} />

  {/* Static fallback for no-JS users and AI scrapers — listed plainly. */}
  <noscript>
    <section class="mt-12" aria-label="Connections (no-JS view)">
      <h2 class="text-xl font-medium">Connections</h2>
      <ul class="mt-4 space-y-6">
        {
          contacts.map((c) => (
            <li>
              <p class="font-medium">
                {c.name} <span class="text-muted">— {c.title}{c.company ? `, ${c.company}` : ''}</span>
              </p>
              <p class="mt-1 text-sm text-muted">{c.blurb}</p>
              <p class="mt-1 text-sm italic text-muted">{c.relationship}</p>
              {c.link && <p class="mt-1 text-sm"><a href={c.link} rel="noopener">{c.link}</a></p>}
            </li>
          ))
        }
      </ul>
      <p class="mt-6 text-sm">
        For an introduction, email <a href={`mailto:${owner.email}`}>{owner.email}</a>
        with the connection's name in the subject line.
      </p>
    </section>
  </noscript>
</BaseLayout>
