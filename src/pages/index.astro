---
// Homepage right column. Identity lives in the SideBar.
// Pure Astro HTML, zero JS on initial paint.
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectCard from '@components/ProjectCard.astro';
import FormattedDate from '@components/FormattedDate.astro';
import { SITE } from '@config';
import { url } from '@lib/url';

const featured = (await getCollection('projects', ({ data }) => !data.draft && data.featured))
  .sort((a, b) => b.data.year.localeCompare(a.data.year))
  .slice(0, 4);

const recentPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<BaseLayout>
  <!-- ABOUT — long-form, follows the short bio in the sidebar -->
  <section id="about" class="mb-20" aria-labelledby="about-heading">
    <h2 id="about-heading" class="sr-only">About</h2>
    <p class="text-base text-muted">{SITE.author.longBio}</p>
  </section>

  <!-- FEATURED WORK -->
  {
    featured.length > 0 && (
      <section id="work" class="mb-20" aria-labelledby="featured-heading">
        <header class="mb-6 flex items-baseline justify-between">
          <h2 id="featured-heading" class="font-mono text-xs uppercase tracking-widest text-fg">
            Featured work
          </h2>
          <a href={url('/work')} class="text-sm">All projects →</a>
        </header>
        <div class="space-y-4">
          {featured.map((p) => <ProjectCard project={p} />)}
        </div>
      </section>
    )
  }

  <!-- RECENT WRITING -->
  {
    recentPosts.length > 0 && (
      <section id="writing" class="mb-20" aria-labelledby="writing-heading">
        <header class="mb-6 flex items-baseline justify-between">
          <h2 id="writing-heading" class="font-mono text-xs uppercase tracking-widest text-fg">
            Recent writing
          </h2>
          <a href={url('/writing')} class="text-sm">All posts →</a>
        </header>
        <ul class="divide-y divide-border">
          {recentPosts.map((post) => (
            <li class="flex flex-col gap-1 py-3 sm:flex-row sm:items-baseline sm:justify-between sm:gap-4">
              <a href={url(`/writing/${post.slug}`)} class="no-underline font-medium text-fg hover:!text-accent">
                {post.data.title}
              </a>
              <span class="font-mono text-xs text-muted">
                <FormattedDate date={post.data.pubDate} />
              </span>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>
