---
// Homepage — long-scroll, multi-section.
// Identity lives in the sticky SideBar. Cross-page nav lives in the TopNav.
// Sidebar in-page nav anchors to the section IDs below.
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectCard from '@components/ProjectCard.astro';
import FormattedDate from '@components/FormattedDate.astro';
import BioIndicator from '@components/BioIndicator.astro';
import CertBadge from '@components/CertBadge.astro';
import { SITE } from '@config';
import { url } from '@lib/url';
import { getBadgeImage, type BadgeImage } from '@lib/cert';
import { experience } from '@data/cv';

// Sidebar in-page anchors — order matches the section order below.
const sections = [
  { id: 'about', label: 'About' },
  { id: 'experience', label: 'Experience' },
  { id: 'projects', label: 'Projects' },
  { id: 'certificates', label: 'Certs' },
  { id: 'articles', label: 'Articles' },
];

// Show the three most-recent roles on the homepage. Full history lives on /cv.
// Pulled from the same source so they never drift apart.
const recentRoles = experience.slice(0, 3).map((job) => ({
  year: `${job.start} — ${job.end === 'present' ? 'Present' : job.end}`,
  role: job.role,
  employer: job.employer,
  summary: job.summary,
  stack: job.stack,
  thoughts: job.thoughts ?? [],
}));

const featured = (await getCollection('projects', ({ data }) => !data.draft && data.featured))
  .sort((a, b) => b.data.year.localeCompare(a.data.year))
  .slice(0, 4);

const recentPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

// Featured (or, if none flagged, most-recent) certificates for the homepage.
// Filter to active credentials only — the homepage is the highlight reel,
// expired credentials live on /certificates#expired with the honest history.
const allCerts = (await getCollection('certificates', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.issueDate.valueOf() - a.data.issueDate.valueOf(),
);
const _now = new Date();
const activeCerts = allCerts.filter((c) => !c.data.expirationDate || c.data.expirationDate > _now);
const featuredCerts = (
  activeCerts.some((c) => c.data.featured)
    ? activeCerts.filter((c) => c.data.featured)
    : activeCerts
).slice(0, 4);

// Pre-resolve each featured cert's badge so we get pixel dimensions for the
// rendered <img> (no CLS) without doing async work in the JSX.
//
// NOTE: data collections (YAML) expose `id` not `slug` — using `slug` here
// returns undefined and silently collapses every entry to the same Map key.
const featuredCertBadges = new Map<string, BadgeImage | null>(
  await Promise.all(
    featuredCerts.map(async (c) => [c.id, await getBadgeImage(c.data.badge)] as const),
  ),
);
---

<BaseLayout split sections={sections}>
  <!-- ABOUT -->
  <section id="about" class="mb-24 scroll-mt-24 last:mb-0" aria-labelledby="about-heading">
    <h2 id="about-heading" class="sr-only">About</h2>
    <div class="space-y-4 text-base text-muted">
      <p>{SITE.author.longBio}</p>
      <p>
        Most of my career has been at the seam between resilient backend systems and the people who
        depend on them not falling over. The work I'm proudest of is invisible — infrastructure you
        only notice when something breaks elsewhere.
      </p>
      <p>
        I write about what I learn at <a href={url('/articles')}>/articles</a> and keep an honest log
        of the projects I started and didn't finish in the <a href={url('/projects') + '#archive'}
          >archive</a
        > at the bottom of /projects. Both feel like an essential counterweight to the highlight-reel
        version of a portfolio.
      </p>
      <p>
        If you want the snapshot of what I'm focused on this season — what I'm building, reading,
        learning — that's at <a href={url('/now')}>/now</a>. Updated whenever it stops being true.
      </p>
    </div>
    {
      /* No indicator here: the About section is already deeply personal —
        the sidebar restores the static `SITE.author.bio` while you're
        viewing it, instead of typing a thought-of-the-day. */
    }
  </section>

  <!-- EXPERIENCE -->
  <section
    id="experience"
    class="mb-24 scroll-mt-24 last:mb-0"
    aria-labelledby="experience-heading"
  >
    <h2
      id="experience-heading"
      class="mb-6 font-mono text-xs uppercase tracking-widest text-fg lg:sr-only"
    >
      Experience
    </h2>
    <ol class="space-y-10">
      {
        /*
         * Each <li> is its own grid container, so a `max-content` column would
         * be re-measured per row — rows with "2024 — Present" would push their
         * content further right than rows with "2023 — 2024". Pin the year
         * column to a fixed width so every row's content starts at the same x.
         * 9rem comfortably fits the widest reasonable label at text-xs +
         * tracking-widest with margin to spare.
         */
        recentRoles.map((job) => (
          <li class="group relative grid grid-cols-1 gap-3 sm:grid-cols-[9rem_1fr]">
            <span class="font-mono text-xs uppercase tracking-widest text-muted sm:pt-1">
              {job.year}
            </span>
            <div>
              <h3 class="font-medium text-fg">
                {job.role} · <span class="text-muted">{job.employer}</span>
              </h3>
              <p class="mt-2 text-sm text-muted">{job.summary}</p>
              <div class="mt-3 flex items-end justify-between gap-3">
                <ul class="flex flex-wrap gap-1.5">
                  {job.stack.map((s) => (
                    <li class="rounded bg-border/70 px-2 py-0.5 font-mono text-xs text-fg/85">
                      {s}
                    </li>
                  ))}
                </ul>
                {/* Per-role indicator — bottom-right of the role's content
                    cell. Wrapper hides on `<lg` so the empty flex slot
                    doesn't even exist on the mobile single-column layout. */}
                <div class="hidden lg:block">
                  <BioIndicator messages={job.thoughts} label={`${job.role} at ${job.employer}`} />
                </div>
              </div>
            </div>
          </li>
        ))
      }
    </ol>
    <p class="mt-8 text-sm">
      <a href={url('/cv')} class="group/cta no-underline">
        <span class="underline decoration-1 underline-offset-2 group-hover/cta:decoration-2"
          >Full CV</span
        >
        <span
          aria-hidden="true"
          class="ml-0.5 inline-block transition-transform duration-200 ease-out group-hover/cta:translate-x-0.5 motion-reduce:transition-none"
          >→</span
        >
      </a>
    </p>
  </section>

  <!-- FEATURED PROJECTS -->
  {
    featured.length > 0 && (
      <section
        id="projects"
        class="mb-24 scroll-mt-24 last:mb-0"
        aria-labelledby="projects-heading"
      >
        <h2
          id="projects-heading"
          class="mb-6 font-mono text-xs uppercase tracking-widest text-fg lg:sr-only"
        >
          Projects
        </h2>
        <div class="space-y-4">
          {featured.map((p) => (
            /* Wrap each card so the indicator can sit at its bottom-right.
               z-20 keeps the button above the card's z-0 overlay link.
               Indicator wrapper hides on `<lg` since the typewriter doesn't
               run there — matches the layout's single-column transition. */
            <div class="relative">
              <ProjectCard project={p} />
              <div class="pointer-events-none absolute bottom-3 right-3 z-20 hidden lg:block">
                <div class="pointer-events-auto">
                  <BioIndicator messages={p.data.thoughts} label={p.data.title} />
                </div>
              </div>
            </div>
          ))}
        </div>
        <p class="mt-8 text-sm">
          <a href={url('/projects')} class="group/cta no-underline">
            <span class="underline decoration-1 underline-offset-2 group-hover/cta:decoration-2">
              All projects
            </span>
            <span
              aria-hidden="true"
              class="ml-0.5 inline-block transition-transform duration-200 ease-out group-hover/cta:translate-x-0.5 motion-reduce:transition-none"
            >
              →
            </span>
          </a>
        </p>
      </section>
    )
  }

  <!-- CERTIFICATES -->
  {
    featuredCerts.length > 0 && (
      <section
        id="certificates"
        class="mb-24 scroll-mt-24 last:mb-0"
        aria-labelledby="certificates-heading"
      >
        <h2
          id="certificates-heading"
          class="mb-6 font-mono text-xs uppercase tracking-widest text-fg lg:sr-only"
        >
          Certifications
        </h2>
        {/*
          Checklist-row layout (NOT cards) so credentials don't read as just
          another flavor of project. Logo + name + issuer + dates is the whole
          payload here. Skills, description, and verify links live on the
          /certificates page where the visitor has signaled they want depth.
        */}
        <ul class="divide-y divide-border">
          {featuredCerts.map((c) => {
            const badge = featuredCertBadges.get(c.id) ?? null;
            const href = c.data.verifyUrl ?? `${url('/certificates')}#${c.id}`;
            const isExternal = c.data.verifyUrl != null;
            return (
              <li class="flex items-center gap-3 py-3">
                <a
                  href={href}
                  rel={isExternal ? 'noopener' : undefined}
                  class="group/cert flex flex-1 items-center gap-3 no-underline"
                >
                  <CertBadge badge={badge} alt={`${c.data.name} badge`} size="sm" />
                  <div class="min-w-0 flex-1">
                    <p class="m-0 truncate font-medium text-fg group-hover/cert:!text-accent">
                      {c.data.name}
                    </p>
                    <p class="m-0 text-xs text-muted">
                      {c.data.issuer}
                      <span class="ml-1 font-mono">
                        · <FormattedDate date={c.data.issueDate} />
                        {c.data.expirationDate && (
                          <>
                            {' – '}
                            <FormattedDate date={c.data.expirationDate} />
                          </>
                        )}
                      </span>
                    </p>
                  </div>
                </a>
                {/* Per-cert thoughts indicator (hidden on mobile, like the others). */}
                <div class="hidden lg:block">
                  <BioIndicator
                    messages={c.data.thoughts}
                    label={`${c.data.name} from ${c.data.issuer}`}
                  />
                </div>
              </li>
            );
          })}
        </ul>
        <p class="mt-8 text-sm">
          <a href={url('/certificates')} class="group/cta no-underline">
            <span class="underline decoration-1 underline-offset-2 group-hover/cta:decoration-2">
              All certifications
            </span>
            <span
              aria-hidden="true"
              class="ml-0.5 inline-block transition-transform duration-200 ease-out group-hover/cta:translate-x-0.5 motion-reduce:transition-none"
            >
              →
            </span>
          </a>
        </p>
      </section>
    )
  }

  <!-- RECENT ARTICLES -->
  {
    recentPosts.length > 0 && (
      <section
        id="articles"
        class="mb-24 scroll-mt-24 last:mb-0"
        aria-labelledby="articles-heading"
      >
        <h2
          id="articles-heading"
          class="mb-6 font-mono text-xs uppercase tracking-widest text-fg lg:sr-only"
        >
          Articles
        </h2>
        <ul class="divide-y divide-border">
          {recentPosts.map((post) => (
            <li class="flex flex-col gap-1 py-3 sm:flex-row sm:items-center sm:justify-between sm:gap-6">
              <a
                href={url(`/articles/${post.slug}`)}
                class="font-medium text-fg no-underline hover:!text-accent"
              >
                {post.data.title}
              </a>
              <div class="flex shrink-0 items-center gap-3">
                <span class="font-mono text-xs text-muted">
                  <FormattedDate date={post.data.pubDate} />
                </span>
                {/* Per-article indicator. Wrapper hides on `<lg`, matching
                    the layout's single-column transition. */}
                <div class="hidden lg:block">
                  <BioIndicator messages={post.data.thoughts} label={post.data.title} />
                </div>
              </div>
            </li>
          ))}
        </ul>
        <p class="mt-8 text-sm">
          <a href={url('/articles')} class="group/cta no-underline">
            <span class="underline decoration-1 underline-offset-2 group-hover/cta:decoration-2">
              All articles
            </span>
            <span
              aria-hidden="true"
              class="ml-0.5 inline-block transition-transform duration-200 ease-out group-hover/cta:translate-x-0.5 motion-reduce:transition-none"
            >
              →
            </span>
          </a>
        </p>
      </section>
    )
  }
</BaseLayout>
