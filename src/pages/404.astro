---
import BaseLayout from '@layouts/BaseLayout.astro';
import { url } from '@lib/url';
---

<BaseLayout title="Not found" description="The page you were looking for doesn't exist." noindex>
  <section class="py-12 text-center">
    <p class="font-mono text-sm text-muted">404</p>
    <h1 class="mt-2 text-3xl font-medium">Page not found</h1>
    <p class="mt-3 text-muted">
      The link is broken, or the page has moved. Try the
      <a href={url('/')}>home page</a> or the <a href={url('/projects')}>projects</a>.
    </p>
  </section>
</BaseLayout>
