---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE, DEFAULT_OG_IMAGE } from '@config';
import { personId, projectUrl, absoluteImage } from '@lib/schema';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft && data.tier === 1);
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { data } = project;

// Pick the most specific schema.org type the data supports:
//   - has a live URL  → SoftwareApplication (LLM/dev-tool indexes key off this)
//   - has a repo only → SoftwareSourceCode
//   - otherwise       → CreativeWork (safe fallback for non-code work)
const schemaType: 'SoftwareApplication' | 'SoftwareSourceCode' | 'CreativeWork' = data.links.live
  ? 'SoftwareApplication'
  : data.links.repo
    ? 'SoftwareSourceCode'
    : 'CreativeWork';

const projectImage = absoluteImage(data.cover ?? DEFAULT_OG_IMAGE);

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': schemaType,
    '@id': projectUrl(project.slug) + '#project',
    name: data.title,
    description: data.summary,
    dateCreated: data.year,
    // Reference the canonical Person — do NOT redeclare it.
    author: { '@id': personId },
    creator: { '@id': personId },
    keywords: data.tags.join(', '),
    ...(data.stack.length > 0 && { programmingLanguage: data.stack }),
    ...(data.links.repo && { codeRepository: data.links.repo }),
    ...(data.links.live && { url: data.links.live }),
    ...(projectImage && { image: projectImage }),
    ...(schemaType === 'SoftwareApplication' && {
      applicationCategory: 'DeveloperApplication',
    }),
  },
];
---

<BaseLayout
  title={data.title}
  description={data.summary}
  type="article"
  schema={schema}
>
  <article class="prose prose-lg max-w-none">
    <header class="not-prose mb-8">
      <p class="font-mono text-sm text-muted">{data.year} · {data.role ?? 'Project'}</p>
      <h1 class="mt-2 text-3xl font-medium sm:text-4xl">{data.title}</h1>
      <p class="mt-3 text-lg text-muted">{data.summary}</p>

      {
        data.stack.length > 0 && (
          <dl class="mt-6 grid grid-cols-[max-content_1fr] gap-x-4 gap-y-2 text-sm">
            <dt class="font-mono text-muted">stack</dt>
            <dd>{data.stack.join(', ')}</dd>
            {data.tags.length > 0 && (
              <>
                <dt class="font-mono text-muted">tags</dt>
                <dd>{data.tags.join(', ')}</dd>
              </>
            )}
            <dt class="font-mono text-muted">status</dt>
            <dd>{data.status}</dd>
          </dl>
        )
      }

      {
        (data.links.live || data.links.repo) && (
          <p class="mt-4 flex gap-4 text-sm">
            {data.links.live && (
              <a href={data.links.live} rel="noopener" class="group/cta no-underline">
                <span class="underline underline-offset-2 decoration-1 group-hover/cta:decoration-2">Live</span>
                <span
                  aria-hidden="true"
                  class="ml-0.5 inline-block transition-transform duration-200 ease-out motion-reduce:transition-none group-hover/cta:translate-x-0.5"
                >→</span>
              </a>
            )}
            {data.links.repo && (
              <a href={data.links.repo} rel="noopener" class="group/cta no-underline">
                <span class="underline underline-offset-2 decoration-1 group-hover/cta:decoration-2">Code</span>
                <span
                  aria-hidden="true"
                  class="ml-0.5 inline-block transition-transform duration-200 ease-out motion-reduce:transition-none group-hover/cta:translate-x-0.5"
                >→</span>
              </a>
            )}
          </p>
        )
      }
    </header>

    <Content />
  </article>
</BaseLayout>
