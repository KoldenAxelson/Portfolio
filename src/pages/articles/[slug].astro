---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import FormattedDate from '@components/FormattedDate.astro';
import { SITE, DEFAULT_OG_IMAGE } from '@config';
import { personId, websiteId, articleUrl, absoluteImage } from '@lib/schema';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((p) => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { data } = post;

const articleImage = absoluteImage(data.cover ?? DEFAULT_OG_IMAGE);

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    '@id': articleUrl(post.slug) + '#article',
    headline: data.title,
    description: data.description,
    datePublished: data.pubDate.toISOString(),
    ...(data.updatedDate && { dateModified: data.updatedDate.toISOString() }),
    // Reference the canonical Person — do NOT redeclare it.
    author: { '@id': personId },
    publisher: { '@id': personId },
    ...(data.tags.length > 0 && { keywords: data.tags.join(', ') }),
    inLanguage: SITE.locale,
    ...(articleImage && { image: articleImage }),
    isPartOf: { '@id': websiteId },
    mainEntityOfPage: articleUrl(post.slug),
  },
];
---

<BaseLayout
  title={data.title}
  description={data.description}
  image={data.cover}
  type="article"
  publishedTime={data.pubDate}
  modifiedTime={data.updatedDate}
  schema={schema}
>
  <article class="prose prose-lg max-w-none">
    <header class="not-prose mb-8">
      <h1 class="text-3xl font-medium sm:text-4xl">{data.title}</h1>
      <p class="mt-3 text-lg text-muted">{data.description}</p>
      <p class="mt-3 flex flex-wrap items-center gap-x-3 font-mono text-sm text-muted">
        <FormattedDate date={data.pubDate} />
        {data.updatedDate && (
          <>
            <span>· updated <FormattedDate date={data.updatedDate} /></span>
          </>
        )}
        {data.tags.length > 0 && <span>· {data.tags.join(', ')}</span>}
      </p>
    </header>

    <Content />
  </article>
</BaseLayout>
