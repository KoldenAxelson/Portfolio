---
// ProjectCard with overlay-link pattern.
//
// The card itself is a single link to the "primary" target:
//   Tier 1 → /projects/[slug]    (the case study page)
//   Tier 2 → links.live or links.repo, whichever is set
//   No primary target → card is not a link (rare; still renders fine)
//
// Inside the card, the optional `metric` field renders as a separate
// inline link that points at source code, a downloads page, reviews, etc.
// Nested links work via the "absolute inset-0" overlay trick: a sibling
// <a> covers the card; inner links get position:relative + z-10 to float
// above it.
//
// Layout: the card is a plain block (NOT flex). The cover image, when
// present, is floated left so the surrounding text flows around it
// naturally — no awkward deadspace under a short image. Tags and the
// metric link use `clear-both` so they always sit below the image
// regardless of how much description text wraps next to it.

import type { CollectionEntry } from 'astro:content';
import { url } from '@lib/url';

interface Props {
  project: CollectionEntry<'projects'>;
  /** Compact mode for Tier 2 listings. */
  compact?: boolean;
}

const { project, compact = false } = Astro.props;
const { data, slug } = project;

// Decide where the card itself navigates.
const primaryHref: string | null = (() => {
  if (data.tier === 1) return url(`/projects/${slug}`);
  if (data.links.live) return data.links.live;
  if (data.links.repo) return data.links.repo;
  return null;
})();

const primaryIsExternal = primaryHref !== null && /^https?:/i.test(primaryHref);

// Heroicons 2.0 — star (solid), user (outline), download (outline).
// Solid for award-ish glyphs; outline for stat-ish glyphs.
type MetricIcon = 'star' | 'user' | 'download';
const METRIC_ICONS: Record<MetricIcon, { fill: string; path: string }> = {
  star: {
    fill: 'currentColor',
    path: 'M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006Z',
  },
  user: {
    fill: 'none',
    path: 'M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z',
  },
  download: {
    fill: 'none',
    path: 'M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3',
  },
};
---

<article
  class:list={[
    'group relative rounded-lg border border-border bg-bg/30 p-5 transition hover:border-accent',
    compact && 'p-4',
  ]}
  itemscope
  itemtype="https://schema.org/CreativeWork"
>
  {
    /* Overlay link covering the whole card. Inner links sit above this. */
    primaryHref && (
      <a
        href={primaryHref}
        rel={primaryIsExternal ? 'noopener' : undefined}
        aria-label={data.title}
        class="absolute inset-0 z-0 rounded-lg"
      />
    )
  }

  {
    /* Optional cover. Path is relative to /public (e.g. "/covers/foo.svg").
       Floated left so the header, description, and tags flow around it.
       Forkers using raster covers should pre-convert to WebP/AVIF for
       Lighthouse perf — see docs/content.md. */
    data.cover && (
      <img
        src={url(data.cover)}
        width={compact ? 64 : 96}
        height={compact ? 64 : 96}
        alt=""
        loading="lazy"
        decoding="async"
        class:list={[
          'pointer-events-none relative z-10 float-left mb-2 rounded-md object-cover',
          compact ? 'mr-3 h-16 w-16' : 'mr-4 h-20 w-20 sm:h-24 sm:w-24',
        ]}
      />
    )
  }

  <header class="relative z-10 mb-2">
    <span class="float-right ml-2 font-mono text-xs text-muted" itemprop="dateCreated">
      {data.year}
    </span>
    <h3
      class:list={[
        'm-0 font-medium transition-colors group-hover:text-accent',
        compact ? 'text-base' : 'text-lg',
      ]}
      itemprop="name"
    >
      {data.title}
    </h3>
  </header>

  <p class="pointer-events-none relative z-10 text-sm text-muted" itemprop="abstract">
    {data.summary}
  </p>

  {
    data.stack.length > 0 && (
      <ul class="pointer-events-none relative z-10 clear-both mt-3 flex flex-wrap gap-1.5">
        {data.stack.map((s) => (
          <li class="rounded bg-border/70 px-1.5 py-0.5 font-mono text-xs text-fg/85">{s}</li>
        ))}
      </ul>
    )
  }

  {
    /*
     * Metric rendering. Schema is `{ icon?, label, href }`:
     *   icon  — 'star' | 'user' | 'download' (see content/config.ts). The
     *           icon conveys the metric TYPE so the units stay out of the
     *           label text. Omit for icon-less labels like "Read the case
     *           study" — just a plain underlined link.
     *   label — '<number> @<venue>' (e.g. "612 @GitHub", "4.8
     *           @SlackMarketplace"). The `@<venue>` portion is italicized
     *           inside the underline. A leading space before `@` is also
     *           tolerated for legacy entries.
     *
     * Render shape: [SVG][underlined: number [italic: @venue]] [↗].
     * The SVG sits OUTSIDE the underlined span so the underline doesn't
     * span the gap between icon and text.
     */
    data.metric &&
      (() => {
        const { icon, label } = data.metric;
        const cleaned = label.replace(/\s+/g, ' ').trim();
        const atIdx = cleaned.indexOf(' @');
        const beforeVenue = atIdx >= 0 ? cleaned.slice(0, atIdx) : cleaned;
        // Strip any whitespace immediately after `@` so "@ X" → "@X".
        const venue =
          atIdx >= 0 ? cleaned.slice(atIdx + 1).replace(/^@\s+/, '@') : null;

        const glyph = icon ? METRIC_ICONS[icon] : null;

        return (
          <p class="relative z-10 clear-both mt-3">
            <a
              href={data.metric.href}
              rel="noopener"
              class="group/metric -my-1 inline-flex items-center gap-1.5 py-1 font-mono text-sm text-accent no-underline"
              itemprop="codeRepository"
            >
              {glyph && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill={glyph.fill}
                  stroke={glyph.fill === 'none' ? 'currentColor' : undefined}
                  stroke-width={glyph.fill === 'none' ? 1.6 : undefined}
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  class="h-4 w-4 shrink-0"
                >
                  <path
                    {...(glyph.fill === 'currentColor'
                      ? { 'fill-rule': 'evenodd', 'clip-rule': 'evenodd' }
                      : {})}
                    d={glyph.path}
                  />
                </svg>
              )}
              <span class="underline decoration-1 underline-offset-2 group-hover/metric:decoration-2">
                {beforeVenue}
                {venue && (
                  <>
                    {' '}
                    <em class="italic">{venue}</em>
                  </>
                )}
              </span>
              <span
                aria-hidden="true"
                class="inline-block transition-transform duration-200 ease-out group-hover/metric:-translate-y-0.5 group-hover/metric:translate-x-0.5 motion-reduce:transition-none"
              >
                ↗
              </span>
            </a>
          </p>
        );
      })()
  }
</article>
