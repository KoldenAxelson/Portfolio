---
// CertBadge — renders the credential's badge image, or a Heroicons SOLID
// trophy fallback if no badge file is set on the cert. Encapsulates ALL
// of the visual logic (img vs fallback, sizing, alt text) so neither the
// homepage nor the /certificates page repeats SVG paths or sizing rules.
//
// Receives a pre-resolved `BadgeImage | null` rather than fetching its
// own — pages already need the resolved badge to emit JSON-LD ImageObject
// with width/height, and re-fetching per-render would double the Sharp
// calls.

import type { BadgeImage } from '@lib/cert';

interface Props {
  /** Pre-resolved badge data, or null when the cert has no badge image. */
  badge: BadgeImage | null;
  /** Alt text for the rendered <img>. Required when badge is non-null. */
  alt: string;
  /** Visual size — controls the box, the image, and the trophy SVG. */
  size?: 'sm' | 'md';
}

const { badge, alt, size = 'sm' } = Astro.props;

// "sm" is the homepage row (40px), "md" is the /certificates row (48px).
const dims = {
  sm: { box: 'h-10 w-10', svg: 'h-6 w-6', fallbackPx: 40 },
  md: { box: 'h-12 w-12', svg: 'h-7 w-7', fallbackPx: 48 },
}[size];
---

{
  badge ? (
    <img
      src={badge.src}
      alt={alt}
      width={badge.width ?? dims.fallbackPx}
      height={badge.height ?? dims.fallbackPx}
      loading="lazy"
      decoding="async"
      class:list={['shrink-0 rounded object-contain', dims.box]}
    />
  ) : (
    <span
      aria-hidden="true"
      class:list={[
        'inline-flex shrink-0 items-center justify-center rounded bg-border/30 text-muted',
        dims.box,
      ]}
    >
      {/* Heroicons 2.0 solid · trophy. Solid renders cleanly at small
          sizes where the outline variant becomes a fuzzy blob. */}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class:list={[dims.svg]}
      >
        <path
          fill-rule="evenodd"
          clip-rule="evenodd"
          d="M5.166 2.621v.858c-1.035.148-2.059.33-3.071.543a.75.75 0 0 0-.584.859 6.753 6.753 0 0 0 6.138 5.6 6.73 6.73 0 0 0 2.743 1.346A6.707 6.707 0 0 1 9.279 15H8.54c-1.036 0-1.875.84-1.875 1.875V19.5h-.75a2.25 2.25 0 0 0-2.25 2.25c0 .414.336.75.75.75h15a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-2.25-2.25h-.75v-2.625c0-1.036-.84-1.875-1.875-1.875h-.739a6.706 6.706 0 0 1-1.112-3.173 6.73 6.73 0 0 0 2.743-1.347 6.753 6.753 0 0 0 6.139-5.6.75.75 0 0 0-.585-.858 47.077 47.077 0 0 0-3.07-.543V2.62a.75.75 0 0 0-.658-.744 49.22 49.22 0 0 0-6.093-.377c-2.063 0-4.096.128-6.093.377a.75.75 0 0 0-.657.744Zm0 2.629c0 1.196.312 2.32.857 3.294A5.266 5.266 0 0 1 3.16 5.337a45.6 45.6 0 0 1 2.006-.343v.256Zm13.5 0v-.256c.674.1 1.343.214 2.006.343a5.265 5.265 0 0 1-2.863 3.207 6.72 6.72 0 0 0 .857-3.294Z"
        />
      </svg>
    </span>
  )
}
