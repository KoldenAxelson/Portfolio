---
// Full-width top nav.
//
//   Desktop (lg+) : inline icon buttons, label slides in on hover.
//   Mobile (<lg)  : hamburger button → dropdown with icon + label items.
//
// Two patterns at play here:
//
//   1. Autohide-on-scroll. The header is sticky at top:0; scrolling down
//      past a threshold translates it up; scrolling up reveals it.
//
//   2. <details>+<summary> for the mobile menu. Native HTML disclosure —
//      keyboard accessible, works without JS. We add a sliver of JS for
//      "click outside" and "Escape" to close.
//
// Adding a new icon: drop the SVG path into the `icons` map below keyed on
// the string you put in SITE.nav[i].icon. Use 24×24 viewBox.

import { SITE } from '@config';
import { url, stripBase } from '@lib/url';

const currentPath = stripBase(Astro.url.pathname).replace(/\/$/, '') || '/';

// Heroicons 2.0 outline-style SVG paths.
const icons: Record<string, string> = {
  globe:
    'M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418',
  'user-group':
    'M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z',
  desktop:
    'M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25',
  briefcase:
    'M20.25 14.15v4.073a2.25 2.25 0 0 1-2.25 2.25h-12a2.25 2.25 0 0 1-2.25-2.25V14.15M16.5 4.5a2.25 2.25 0 0 0-2.25-2.25h-4.5A2.25 2.25 0 0 0 7.5 4.5v.75h9V4.5ZM3 7.5h18v6.75a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V7.5Z',
  folder:
    'M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z',
  newspaper:
    'M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5M6 7.5h3v3H6v-3Z',
  fire:
    'M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48ZM12 18a3.75 3.75 0 0 0 .495-7.467 5.99 5.99 0 0 0-1.925 3.546 5.974 5.974 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z',
};
---

<header
  data-top-nav
  class="sticky top-0 z-40 w-full transition-transform duration-200 ease-out motion-reduce:transition-none print:hidden"
>
  {/*
    Bar wrapper carries the visual chrome (bg + border + backdrop-blur).
    The <header> itself has no backdrop-filter, which is critical: an
    element with backdrop-filter becomes a "backdrop root" that isolates
    backdrop-filter on any descendant. Putting the blur on this inner div
    instead of the header lets the mobile dropdown panel below (which is
    a SIBLING of this div, not a descendant) also use backdrop-filter
    against the actual page content rather than an empty isolated layer.
    See: https://drafts.csswg.org/filter-effects-2/#BackdropRoot
  */}
  <div class="border-b border-border bg-bg/85 backdrop-blur supports-[backdrop-filter]:bg-bg/70">
    <div class="mx-auto flex max-w-screen-xl items-center justify-between gap-4 px-6 py-3 lg:px-12">
    <a
      href={url('/')}
      class="font-mono text-sm font-medium text-fg no-underline hover:!text-accent"
    >
      {SITE.author.name}
    </a>

    <!-- ─── Desktop nav: inline icon row with hover-expand ─── -->
    <nav aria-label="Site" class="hidden lg:block">
      <ul class="flex items-center gap-2">
        {
          SITE.nav.map((item) => {
            const isActive =
              currentPath === item.href || currentPath.startsWith(item.href + '/');
            const path = icons[item.icon as keyof typeof icons];
            return (
              <li>
                <a
                  href={url(item.href)}
                  aria-label={item.label}
                  aria-current={isActive ? 'page' : undefined}
                  class:list={[
                    'group inline-flex items-center rounded-full px-2 py-2 no-underline transition-colors duration-200',
                    isActive
                      ? 'bg-border/60 text-fg'
                      : 'text-muted hover:!text-fg hover:bg-border/40',
                  ]}
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    class="h-5 w-5 shrink-0 transition-transform duration-300 ease-out group-hover:scale-110 group-hover:rotate-[-3deg]"
                  >
                    <path d={path} />
                  </svg>
                  <span
                    class:list={[
                      'whitespace-nowrap text-sm',
                      isActive
                        ? 'ml-2'
                        : 'ml-0 max-w-0 overflow-hidden opacity-0 transition-all duration-300 ease-out motion-reduce:transition-none group-hover:ml-2 group-hover:max-w-[8rem] group-hover:opacity-100 group-focus-within:ml-2 group-focus-within:max-w-[8rem] group-focus-within:opacity-100',
                    ]}
                  >
                    {item.label}
                  </span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <!-- ─── Mobile nav: hamburger → header expands ───
         Tesla-style: tapping the hamburger expands the header bar downward
         into a full-width panel of large stacked links. The panel is
         absolutely positioned beneath the header bar (the sticky <header>
         is its containing block — that's why <details> doesn't carry
         `relative` here), so it slides under the bar's existing border
         and matches its background for visual continuity. -->
    <details data-mobile-nav class="lg:hidden">
      <summary
        aria-label="Open menu"
        class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-md text-muted transition-colors hover:bg-border/40 hover:text-fg focus-visible:bg-border/40 focus-visible:text-fg"
      >
        <span class="sr-only">Menu</span>
        <svg
          class="icon-bars h-7 w-7"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg
          class="icon-close h-7 w-7"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M6 18L18 6M6 6l12 12" />
        </svg>
      </summary>

    </details>
    </div>
  </div>

  {/*
    Mobile dropdown panel — SIBLING of the bar wrapper (not a descendant),
    so it doesn't inherit the bar's backdrop-root isolation. This is the
    sole reason the panel's `backdrop-filter` actually blurs page content
    instead of an empty layer. See the bar wrapper's comment above.

    Animation: the outer <div> uses the `grid-template-rows: 0fr → 1fr`
    trick to transition the panel's height to its natural content size
    without any JS measurement. The inner <nav> needs `overflow: hidden`
    so the content is clipped while the row is collapsed. The items
    (<ul>) fade in with a delay so they don't pop in mid-expansion.
    Visibility is driven by the <details>'s `[open]` state via the
    `.is-open` class toggled by the script at the bottom of this file.
  */}
  <div
    data-mobile-panel
    class="absolute inset-x-0 top-full z-40 grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out motion-reduce:transition-none lg:hidden"
  >
    <nav
      aria-label="Site (mobile)"
      class="overflow-hidden border-b border-border bg-bg/85 backdrop-blur supports-[backdrop-filter]:bg-bg/70"
    >
      <ul class="mx-auto flex max-w-screen-xl flex-col gap-1 px-6 py-4 opacity-0 transition-opacity duration-200 ease-out motion-reduce:transition-none">
        {
          SITE.nav.map((item) => {
            const isActive =
              currentPath === item.href || currentPath.startsWith(item.href + '/');
            const path = icons[item.icon as keyof typeof icons];
            return (
              <li>
                <a
                  href={url(item.href)}
                  aria-current={isActive ? 'page' : undefined}
                  class:list={[
                    'flex items-center gap-4 rounded-md px-3 py-3 text-lg no-underline transition-colors',
                    isActive
                      ? 'bg-border/60 font-medium text-fg'
                      : 'text-fg/85 hover:bg-border/40 hover:!text-accent',
                  ]}
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    class="h-6 w-6 shrink-0"
                  >
                    <path d={path} />
                  </svg>
                  <span>{item.label}</span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<!-- Icon swap based on open state. Pure CSS, no JS. -->
<style>
  [data-mobile-nav] > summary::-webkit-details-marker {
    display: none;
  }
  [data-mobile-nav] > summary::marker {
    display: none;
  }
  [data-mobile-nav][open] .icon-bars {
    display: none;
  }
  [data-mobile-nav]:not([open]) .icon-close {
    display: none;
  }
  /* Mobile dropdown panel — animated by JS toggling `.is-open` (instead
     of `:has()`) so older browsers without `:has()` still get the menu
     reliably. The panel's height transitions via the grid-rows trick:
     the outer wrapper is a 1-row grid, with the row interpolating from
     0fr to 1fr. Items fade in with a delay only on opening so the panel
     finishes expanding before the labels appear; on closing the items
     fade out simultaneously with the collapse for snappier dismissal. */
  [data-mobile-panel].is-open {
    grid-template-rows: 1fr;
  }
  [data-mobile-panel].is-open ul {
    opacity: 1;
    transition-delay: 200ms;
  }
</style>

<script is:inline>
  (function () {
    // ─── Autohide on scroll-down, reveal on scroll-up ───
    const nav = document.querySelector('[data-top-nav]');
    if (nav) {
      let lastY = window.scrollY;
      let ticking = false;
      const THRESHOLD = 50;

      function onScroll() {
        const y = window.scrollY;
        if (y < THRESHOLD) {
          nav.style.transform = '';
        } else if (y > lastY + 4) {
          nav.style.transform = 'translateY(-100%)';
        } else if (y < lastY - 4) {
          nav.style.transform = '';
        }
        lastY = y;
        ticking = false;
      }

      window.addEventListener(
        'scroll',
        () => {
          if (!ticking) {
            requestAnimationFrame(onScroll);
            ticking = true;
          }
        },
        { passive: true },
      );
    }

    // ─── Mobile menu: close on click-outside or Escape ───
    // Also: sync the panel's `.is-open` class with the <details> open state.
    // The panel lives OUTSIDE <details> (so its `backdrop-filter` isn't
    // isolated by the bar's backdrop root), which means it can't piggyback
    // on the native <details> show/hide. We sync via the `toggle` event.
    const mobileNav = document.querySelector('[data-mobile-nav]');
    const mobilePanel = document.querySelector('[data-mobile-panel]');
    if (mobileNav) {
      const syncPanel = () => {
        if (mobilePanel) mobilePanel.classList.toggle('is-open', mobileNav.open);
      };
      mobileNav.addEventListener('toggle', syncPanel);
      syncPanel();

      document.addEventListener('click', (e) => {
        if (!mobileNav.open) return;
        const insideNav = mobileNav.contains(e.target);
        const insidePanel = mobilePanel && mobilePanel.contains(e.target);
        if (!insideNav && !insidePanel) {
          mobileNav.open = false;
        }
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mobileNav.open) {
          mobileNav.open = false;
        }
      });
    }
  })();
</script>
