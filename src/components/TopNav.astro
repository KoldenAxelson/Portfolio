---
// Full-width top nav.
//
//   Desktop (lg+) : inline icon buttons, label slides in on hover.
//   Mobile (<lg)  : hamburger button → dropdown with icon + label items.
//
// Two patterns at play here:
//
//   1. Autohide-on-scroll. The header is sticky at top:0; scrolling down
//      past a threshold translates it up; scrolling up reveals it.
//
//   2. <details>+<summary> for the mobile menu. Native HTML disclosure —
//      keyboard accessible, works without JS. We add a sliver of JS for
//      "click outside" and "Escape" to close.
//
// Adding a new icon: drop the SVG path into the `icons` map below keyed on
// the string you put in SITE.nav[i].icon. Use 24×24 viewBox.

import { SITE } from '@config';
import { url, stripBase } from '@lib/url';

const currentPath = stripBase(Astro.url.pathname).replace(/\/$/, '') || '/';

// Heroicons 2.0 outline-style SVG paths.
const icons: Record<string, string> = {
  globe:
    'M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418',
  'user-group':
    'M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z',
  desktop:
    'M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25',
  briefcase:
    'M20.25 14.15v4.073a2.25 2.25 0 0 1-2.25 2.25h-12a2.25 2.25 0 0 1-2.25-2.25V14.15M16.5 4.5a2.25 2.25 0 0 0-2.25-2.25h-4.5A2.25 2.25 0 0 0 7.5 4.5v.75h9V4.5ZM3 7.5h18v6.75a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V7.5Z',
  folder:
    'M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z',
  newspaper:
    'M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5M6 7.5h3v3H6v-3Z',
  fire:
    'M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48ZM12 18a3.75 3.75 0 0 0 .495-7.467 5.99 5.99 0 0 0-1.925 3.546 5.974 5.974 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z',
  'academic-cap':
    'M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5',
  trophy:
    'M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 0 0 2.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 0 1 2.916.52 6.003 6.003 0 0 1-5.395 4.972m0 0a6.726 6.726 0 0 1-2.749 1.35m0 0a6.772 6.772 0 0 1-3.044 0',
};
---

<header
  data-top-nav
  class="sticky top-0 z-40 w-full transition-transform duration-200 ease-out motion-reduce:transition-none print:hidden"
>
  {/*
    Bar wrapper carries the visual chrome (bg + border + backdrop-blur).
    The <header> itself has no backdrop-filter, which is critical: an
    element with backdrop-filter becomes a "backdrop root" that isolates
    backdrop-filter on any descendant. Putting the blur on this inner div
    instead of the header lets the mobile dropdown panel below (which is
    a SIBLING of this div, not a descendant) also use backdrop-filter
    against the actual page content rather than an empty isolated layer.
    See: https://drafts.csswg.org/filter-effects-2/#BackdropRoot
  */}
  <div class="border-b border-border bg-bg/85 backdrop-blur supports-[backdrop-filter]:bg-bg/70">
    <div class="mx-auto flex max-w-screen-xl items-center justify-between gap-4 px-6 py-3 lg:px-12">
    <a
      href={url('/')}
      class="font-mono text-sm font-medium text-fg no-underline hover:!text-accent"
    >
      {SITE.author.name}
    </a>

    <!-- ─── Desktop nav: inline icon row with hover-expand ─── -->
    <nav aria-label="Site" class="hidden lg:block">
      <ul class="flex items-center gap-2">
        {
          SITE.nav.map((item) => {
            const isActive =
              currentPath === item.href || currentPath.startsWith(item.href + '/');
            const path = icons[item.icon as keyof typeof icons];
            return (
              <li>
                <a
                  href={url(item.href)}
                  aria-label={item.label}
                  aria-current={isActive ? 'page' : undefined}
                  class:list={[
                    'group inline-flex items-center rounded-full px-2 py-2 no-underline transition-colors duration-200',
                    isActive
                      ? 'bg-border/60 text-fg'
                      : 'text-muted hover:!text-fg hover:bg-border/40',
                  ]}
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    class="h-5 w-5 shrink-0 transition-transform duration-300 ease-out group-hover:scale-110 group-hover:rotate-[-3deg]"
                  >
                    <path d={path} />
                  </svg>
                  <span
                    class:list={[
                      'whitespace-nowrap text-sm',
                      isActive
                        ? 'ml-2'
                        : 'ml-0 max-w-0 overflow-hidden opacity-0 transition-all duration-300 ease-out motion-reduce:transition-none group-hover:ml-2 group-hover:max-w-[8rem] group-hover:opacity-100 group-focus-within:ml-2 group-focus-within:max-w-[8rem] group-focus-within:opacity-100',
                    ]}
                  >
                    {item.label}
                  </span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <!-- ─── Mobile nav: hamburger → header expands ───
         Tesla-style: tapping the hamburger expands the header bar downward
         into a full-width panel of large stacked links. The panel is
         absolutely positioned beneath the header bar (the sticky <header>
         is its containing block — that's why <details> doesn't carry
         `relative` here), so it slides under the bar's existing border
         and matches its background for visual continuity. -->
    <details data-mobile-nav class="lg:hidden">
      <summary
        aria-label="Open menu"
        class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-md text-muted transition-colors hover:bg-border/40 hover:text-fg focus-visible:bg-border/40 focus-visible:text-fg"
      >
        <span class="sr-only">Menu</span>
        <svg
          class="icon-bars h-7 w-7"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg
          class="icon-close h-7 w-7"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M6 18L18 6M6 6l12 12" />
        </svg>
      </summary>

    </details>
    </div>
  </div>

  {/*
    Mobile dropdown panel — SIBLING of the bar wrapper (not a descendant),
    so it doesn't inherit the bar's backdrop-root isolation. This is the
    sole reason the panel's `backdrop-filter` actually blurs page content
    instead of an empty layer. See the bar wrapper's comment above.

    Animation: the outer <div> uses the `grid-template-rows: 0fr → 1fr`
    trick to transition the panel's height to its natural content size
    without any JS measurement. The inner <nav> needs `overflow: hidden`
    so the content is clipped while the row is collapsed. The items
    (<ul>) fade in with a delay so they don't pop in mid-expansion.
    Visibility is driven by the <details>'s `[open]` state via the
    `.is-open` class toggled by the script at the bottom of this file.
  */}
  <div
    data-mobile-panel
    data-mode="nav"
    class="absolute inset-x-0 top-full z-40 grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out motion-reduce:transition-none lg:hidden"
  >
    {/*
      Single overflow container that clips both modes during the
      height transition. The two children (nav vs bio) swap visibility
      via the parent's `data-mode` attribute — see <style> below.
    */}
    <div class="overflow-hidden border-b border-border bg-bg/85 backdrop-blur supports-[backdrop-filter]:bg-bg/70">
      {/* ─── Nav mode (default) — site navigation links ─── */}
      <nav data-mobile-panel-nav aria-label="Site (mobile)">
        <ul class="mx-auto flex max-w-screen-xl flex-col gap-1 px-6 py-4 opacity-0 transition-opacity duration-200 ease-out motion-reduce:transition-none">
          {
            SITE.nav.map((item) => {
              const isActive =
                currentPath === item.href || currentPath.startsWith(item.href + '/');
              const path = icons[item.icon as keyof typeof icons];
              return (
                <li>
                  <a
                    href={url(item.href)}
                    aria-current={isActive ? 'page' : undefined}
                    class:list={[
                      'flex items-center gap-4 rounded-md px-3 py-3 text-lg no-underline transition-colors',
                      isActive
                        ? 'bg-border/60 font-medium text-fg'
                        : 'text-fg/85 hover:bg-border/40 hover:!text-accent',
                    ]}
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.6"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                      class="h-6 w-6 shrink-0"
                    >
                      <path d={path} />
                    </svg>
                    <span>{item.label}</span>
                  </a>
                </li>
              );
            })
          }
        </ul>
      </nav>

      {/* ─── Bio mode — typewriter content for tapped BioIndicators ───
          The hamburger flips to X when this is open (driven by the same
          [data-mobile-nav][open] state as nav mode), and the X closes it.
          Switching from nav→bio (or bio→bio) re-types the new message. */}
      <div data-mobile-panel-bio class="mx-auto max-w-screen-xl px-6 py-5">
        <p
          data-bio-mobile-typer
          aria-live="polite"
          class="m-0 min-h-[3rem] text-base leading-snug text-fg/90 opacity-0 transition-opacity duration-200 ease-out motion-reduce:transition-none"
        />
      </div>
    </div>
  </div>
</header>

<!-- Icon swap based on open state. Pure CSS, no JS. -->
<style>
  [data-mobile-nav] > summary::-webkit-details-marker {
    display: none;
  }
  [data-mobile-nav] > summary::marker {
    display: none;
  }
  [data-mobile-nav][open] .icon-bars {
    display: none;
  }
  [data-mobile-nav]:not([open]) .icon-close {
    display: none;
  }
  /* Mobile dropdown panel — animated by JS toggling `.is-open` (instead
     of `:has()`) so older browsers without `:has()` still get the menu
     reliably. The panel's height transitions via the grid-rows trick:
     the outer wrapper is a 1-row grid, with the row interpolating from
     0fr to 1fr. Items fade in with a delay only on opening so the panel
     finishes expanding before the labels appear; on closing the items
     fade out simultaneously with the collapse for snappier dismissal. */
  [data-mobile-panel].is-open {
    grid-template-rows: 1fr;
  }
  /* Two modes share the same panel container — only one is visible
     at a time, controlled by the parent's data-mode attribute.
     `nav` is the default (hamburger menu); `bio` swaps in when a
     BioIndicator on the page is tapped. */
  [data-mobile-panel][data-mode='bio'] [data-mobile-panel-nav] {
    display: none;
  }
  [data-mobile-panel][data-mode='nav'] [data-mobile-panel-bio] {
    display: none;
  }
  [data-mobile-panel].is-open [data-mobile-panel-nav] ul,
  [data-mobile-panel].is-open [data-mobile-panel-bio] p {
    opacity: 1;
    transition-delay: 200ms;
  }
</style>

<script is:inline>
  (function () {
    // ─── Autohide on scroll-down, reveal on scroll-up ───
    const nav = document.querySelector('[data-top-nav]');
    // Queried up here (rather than further down) so the autohide handler
    // can check `mobileNav.open` and skip hiding the navbar while the
    // mobile panel is expanded — otherwise scrolling-to-read inside the
    // bio panel (or just opened nav menu) yanks the whole thing off-screen.
    const mobileNav = document.querySelector('[data-mobile-nav]');
    if (nav) {
      let lastY = window.scrollY;
      let ticking = false;
      const THRESHOLD = 50;

      function onScroll() {
        const y = window.scrollY;
        // Skip the autohide entirely while the mobile panel is open in
        // either mode (nav links or bio typewriter). Track lastY anyway
        // so we don't fire a false hide the moment the panel closes.
        if (mobileNav && mobileNav.open) {
          lastY = y;
          ticking = false;
          return;
        }
        if (y < THRESHOLD) {
          nav.style.transform = '';
        } else if (y > lastY + 4) {
          nav.style.transform = 'translateY(-100%)';
        } else if (y < lastY - 4) {
          nav.style.transform = '';
        }
        lastY = y;
        ticking = false;
      }

      window.addEventListener(
        'scroll',
        () => {
          if (!ticking) {
            requestAnimationFrame(onScroll);
            ticking = true;
          }
        },
        { passive: true },
      );
    }

    // ─── Mobile menu: close on click-outside or Escape ───
    // Also: sync the panel's `.is-open` class with the <details> open state.
    // The panel lives OUTSIDE <details> (so its `backdrop-filter` isn't
    // isolated by the bar's backdrop root), which means it can't piggyback
    // on the native <details> show/hide. We sync via the `toggle` event.
    //
    // The same panel container hosts TWO modes:
    //   • `data-mode="nav"` — site nav links (default, hamburger-driven)
    //   • `data-mode="bio"` — typewriter for a tapped BioIndicator
    // The hamburger flips to X whenever the panel is open in either mode.
    // Tapping the X (native <summary> click → details closes) collapses
    // the panel regardless of which mode it's in.
    // (mobileNav already declared above for the autohide guard)
    const mobilePanel = document.querySelector('[data-mobile-panel]');
    const bioTyper = document.querySelector('[data-bio-mobile-typer]');
    // Bio indicators live in main content, which renders AFTER this script.
    // Query lazily inside the wireBioIndicators() call, deferred to
    // DOMContentLoaded so the selector actually finds them.
    let bioIndicators = [];
    // Hoisted to the IIFE scope so syncPanel can bump it on close — that
    // cancels any in-flight typing, otherwise it'd keep writing into the
    // typer after dismissal and a stale message would re-appear briefly
    // when the next indicator was tapped.
    let bioTypingToken = 0;

    if (mobileNav) {
      const summary = mobileNav.querySelector('summary');

      const syncPanel = () => {
        if (mobilePanel) mobilePanel.classList.toggle('is-open', mobileNav.open);
        // On close, clear the active highlight on every BioIndicator.
        if (!mobileNav.open) {
          bioIndicators.forEach((i) => i.setAttribute('data-active', 'false'));
          // Wipe leftover bio context so the next open starts clean —
          // bumping the token cancels any still-typing animation, and
          // clearing textContent removes a fully-typed message that
          // would otherwise flash for ~280ms before the new typing
          // catches up to the panel-open animation.
          bioTypingToken += 1;
          if (bioTyper) bioTyper.textContent = '';
        }
      };
      mobileNav.addEventListener('toggle', syncPanel);
      syncPanel();

      // Tapping the hamburger summary (native click) toggles the details.
      // When opening, default to nav mode. (Bio mode is set explicitly
      // by the BioIndicator click handler below.)
      if (summary) {
        summary.addEventListener('click', () => {
          if (!mobileNav.open && mobilePanel) mobilePanel.dataset.mode = 'nav';
        });
      }

      // ─── BioIndicator clicks → open panel in bio mode + type message ───
      // The mobile sidebar typewriter is hidden, so per-element thoughts
      // get surfaced through the navbar panel instead. One indicator's
      // panel at a time; tapping another swaps the message in place.
      //
      // Deferred to DOMContentLoaded because bio indicators live in main
      // content, which renders AFTER this script tag — querying at script
      // parse time would find an empty list.
      function wireBioIndicators() {
        if (!mobilePanel || !bioTyper) return;
        bioIndicators = Array.from(document.querySelectorAll('[data-bio-indicator]'));
        if (!bioIndicators.length) return;

        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        function pickRandom(arr) {
          if (!arr || !arr.length) return null;
          return arr[Math.floor(Math.random() * arr.length)];
        }

        function readMessages(indicator) {
          try {
            const parsed = JSON.parse(indicator.getAttribute('data-bio-messages') || '[]');
            return Array.isArray(parsed) ? parsed : [];
          } catch (_) {
            return [];
          }
        }

        function sleep(ms) {
          return new Promise((r) => setTimeout(r, ms));
        }

        async function typeInto(element, message) {
          // Token lives at the IIFE scope (bioTypingToken) so syncPanel can
          // bump it on dismiss to cancel any in-flight typing.
          const myToken = ++bioTypingToken;
          if (reduceMotion) {
            element.textContent = message;
            return;
          }
          element.textContent = '';
          let typed = '';
          for (const ch of message) {
            if (bioTypingToken !== myToken) return;
            typed += ch;
            element.textContent = typed;
            const isPunct = /[.!?,;:]/.test(ch);
            await sleep(isPunct ? 140 : 28 + Math.random() * 24);
          }
        }

        for (const indicator of bioIndicators) {
          if (indicator.disabled) continue;
          indicator.addEventListener('click', (e) => {
            // Only intercept on mobile — desktop's SideBar script handles
            // these clicks differently (drives the sidebar typewriter).
            if (window.matchMedia('(min-width: 1024px)').matches) return;

            e.preventDefault();
            e.stopPropagation();

            const msg = pickRandom(readMessages(indicator));
            if (!msg) return;

            const wasOpen = mobileNav.open;
            mobilePanel.dataset.mode = 'bio';
            bioIndicators.forEach((i) =>
              i.setAttribute('data-active', i === indicator ? 'true' : 'false'),
            );
            // If the navbar was hidden by the scroll-down autohide
            // (transform: translateY(-100%)), reveal it — otherwise the
            // expanded bio panel attaches to an off-screen navbar and
            // the user sees nothing. Once mobileNav.open flips to true,
            // the autohide guard above keeps it visible until close.
            if (nav) nav.style.transform = '';
            if (!wasOpen) mobileNav.open = true;

            // If the panel was closed, wait for the open animation before
            // typing so the text isn't visually clipped during expansion.
            const delay = wasOpen || reduceMotion ? 0 : 280;
            setTimeout(() => typeInto(bioTyper, msg), delay);
          });
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', wireBioIndicators);
      } else {
        wireBioIndicators();
      }

      document.addEventListener('click', (e) => {
        if (!mobileNav.open) return;
        const insideNav = mobileNav.contains(e.target);
        const insidePanel = mobilePanel && mobilePanel.contains(e.target);
        const onBioIndicator = e.target.closest && e.target.closest('[data-bio-indicator]');
        if (!insideNav && !insidePanel && !onBioIndicator) {
          mobileNav.open = false;
        }
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mobileNav.open) {
          mobileNav.open = false;
        }
      });
    }
  })();
</script>
