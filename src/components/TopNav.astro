---
// Full-width top navigation, edge-to-edge with a border-bottom.
// Autohide-on-scroll: stays at the top of the page when scrolled near the top,
// hides on scroll-down past the threshold, reveals on scroll-up.
import { SITE } from '@config';
import { url, stripBase } from '@lib/url';

const currentPath = stripBase(Astro.url.pathname).replace(/\/$/, '') || '/';
---

<header
  data-top-nav
  class="sticky top-0 z-40 w-full transform-gpu border-b border-border bg-bg/85 backdrop-blur transition-transform duration-200 ease-out supports-[backdrop-filter]:bg-bg/70 motion-reduce:transition-none"
>
  <div class="mx-auto flex max-w-screen-xl items-center justify-between gap-4 px-6 py-3 lg:px-12">
    <a
      href={url('/')}
      class="font-mono text-sm font-medium text-fg no-underline hover:!text-accent"
    >
      {SITE.author.name}
    </a>
    <nav aria-label="Site">
      <ul class="flex flex-wrap items-center gap-x-5 gap-y-1 text-sm">
        {
          SITE.nav.map((item) => {
            const isActive =
              currentPath === item.href || currentPath.startsWith(item.href + '/');
            return (
              <li>
                <a
                  href={url(item.href)}
                  class:list={[
                    'no-underline',
                    isActive ? 'text-fg font-medium' : 'text-muted hover:!text-fg',
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  // Autohide on scroll-down, reveal on scroll-up.
  (function () {
    const nav = document.querySelector('[data-top-nav]');
    if (!nav) return;
    let lastY = window.scrollY;
    let ticking = false;
    const THRESHOLD = 50;

    function onScroll() {
      const y = window.scrollY;
      if (y < THRESHOLD) {
        nav.style.transform = '';
      } else if (y > lastY + 4) {
        nav.style.transform = 'translateY(-100%)';
      } else if (y < lastY - 4) {
        nav.style.transform = '';
      }
      lastY = y;
      ticking = false;
    }

    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          requestAnimationFrame(onScroll);
          ticking = true;
        }
      },
      { passive: true },
    );
  })();
</script>
