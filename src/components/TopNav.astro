---
// Full-width top nav with icon-only desktop nav + hover-reveal labels.
//
// Two patterns at play here:
//
//  1. Autohide-on-scroll. The header is sticky at top:0; scrolling down past
//     a threshold translates it up out of view; scrolling up reveals it again.
//
//  2. Icon-with-expanding-label. On desktop, each nav item is just an icon.
//     Hovering expands the pill and slides the label in with a coordinated
//     max-width + opacity + margin transition. On mobile, the label is
//     always visible alongside the icon (no hover on touch devices).
//
// Adding a new icon: drop the SVG into the `icons` map below keyed on the
// string you put in SITE.nav[i].icon. Use 24×24 viewBox, currentColor stroke,
// outline style to match Heroicons.

import { SITE } from '@config';
import { url, stripBase } from '@lib/url';

const currentPath = stripBase(Astro.url.pathname).replace(/\/$/, '') || '/';

// Heroicons 2.0 outline-style SVG paths. Add more as needed.
const icons: Record<string, string> = {
  globe:
    'M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418',
  desktop:
    'M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25',
};
---

<header
  data-top-nav
  class="sticky top-0 z-40 w-full transform-gpu border-b border-border bg-bg/85 backdrop-blur transition-transform duration-200 ease-out supports-[backdrop-filter]:bg-bg/70 motion-reduce:transition-none"
>
  <div class="mx-auto flex max-w-screen-xl items-center justify-between gap-4 px-6 py-3 lg:px-12">
    <a
      href={url('/')}
      class="font-mono text-sm font-medium text-fg no-underline hover:!text-accent"
    >
      {SITE.author.name}
    </a>
    <nav aria-label="Site">
      <ul class="flex items-center gap-1 sm:gap-2">
        {
          SITE.nav.map((item) => {
            const isActive =
              currentPath === item.href || currentPath.startsWith(item.href + '/');
            const path = icons[item.icon as keyof typeof icons];
            return (
              <li>
                <a
                  href={url(item.href)}
                  aria-label={item.label}
                  aria-current={isActive ? 'page' : undefined}
                  class:list={[
                    'group inline-flex items-center rounded-full px-2 py-2 no-underline transition-colors duration-200',
                    isActive
                      ? 'bg-border/60 text-fg'
                      : 'text-muted hover:!text-fg hover:bg-border/40',
                  ]}
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    class="h-5 w-5 shrink-0 transition-transform duration-300 ease-out group-hover:scale-110 group-hover:rotate-[-3deg]"
                  >
                    <path d={path} />
                  </svg>
                  <span
                    class:list={[
                      'whitespace-nowrap text-sm',
                      // Mobile: always show label inline.
                      'ml-2',
                      // Desktop: hide until hover (or when active), then slide in.
                      isActive
                        ? 'lg:ml-2'
                        : [
                            'lg:ml-0 lg:max-w-0 lg:overflow-hidden lg:opacity-0',
                            'lg:transition-all lg:duration-300 lg:ease-out lg:motion-reduce:transition-none',
                            'lg:group-hover:ml-2 lg:group-hover:max-w-[8rem] lg:group-hover:opacity-100',
                            'lg:group-focus-within:ml-2 lg:group-focus-within:max-w-[8rem] lg:group-focus-within:opacity-100',
                          ].join(' '),
                    ]}
                  >
                    {item.label}
                  </span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  // Autohide on scroll-down, reveal on scroll-up.
  (function () {
    const nav = document.querySelector('[data-top-nav]');
    if (!nav) return;
    let lastY = window.scrollY;
    let ticking = false;
    const THRESHOLD = 50;

    function onScroll() {
      const y = window.scrollY;
      if (y < THRESHOLD) {
        nav.style.transform = '';
      } else if (y > lastY + 4) {
        nav.style.transform = 'translateY(-100%)';
      } else if (y < lastY - 4) {
        nav.style.transform = '';
      }
      lastY = y;
      ticking = false;
    }

    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          requestAnimationFrame(onScroll);
          ticking = true;
        }
      },
      { passive: true },
    );
  })();
</script>
