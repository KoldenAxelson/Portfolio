---
import { SITE } from '@config';
import SocialIcons from '@components/SocialIcons.astro';

const year = new Date().getFullYear();
// Plain-text stack disclosure — STRATEGY checklist item.
const stack = ['Astro', 'Vue', 'Tailwind', 'MDX'];
---

<footer class="mt-24 border-t border-border pb-12 pt-8 text-sm text-muted">
  {/* Stay stacked (icons below copyright) until `lg`, where the
      ScrollToTop floating button vanishes. Below `lg`, an inline row
      would put the icons in the bottom-right corner where the
      scroll-to-top button overlaps them. */}
  <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
    <p>
      © {year}
      {SITE.author.name}. Built with {stack.join(', ')}. Powered by
      <a href="https://github.com/KoldenAxelson/neofolio" rel="noopener">Neofolio</a>.
    </p>
    <SocialIcons />
  </div>
</footer>
