---
import { SITE } from '@config';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav class="border-b border-border" aria-label="Primary">
  <div class="mx-auto flex max-w-3xl items-center justify-between gap-6 px-4 py-4">
    <a href="/" class="font-mono text-sm font-medium no-underline" aria-label="Home">
      {SITE.author.name}
    </a>
    <ul class="flex flex-wrap items-center gap-x-5 gap-y-1 text-sm">
      {
        SITE.nav.map((item) => {
          const isActive = currentPath === item.href || currentPath.startsWith(item.href + '/');
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  'no-underline',
                  isActive ? 'text-fg font-medium' : 'text-muted hover:text-fg',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</nav>
