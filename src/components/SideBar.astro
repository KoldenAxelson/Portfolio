---
// SideBar — identity + vertical nav + socials.
// Sticky on lg+; stacks at the top on mobile.
import { SITE } from '@config';
import { url, stripBase } from '@lib/url';
import SocialIcons from '@components/SocialIcons.astro';

const currentPath = stripBase(Astro.url.pathname).replace(/\/$/, '') || '/';
const isHome = currentPath === '/';
---

<aside
  class="lg:sticky lg:top-0 lg:flex lg:max-h-screen lg:w-1/2 lg:flex-col lg:justify-between lg:py-24 py-12 lg:pr-8"
>
  <div>
    {
      isHome ? (
        <h1 class="text-4xl font-bold tracking-tight text-fg sm:text-5xl">
          <a href={url('/')} class="hover:!text-fg">{SITE.author.name}</a>
        </h1>
      ) : (
        <p class="text-4xl font-bold tracking-tight text-fg sm:text-5xl">
          <a href={url('/')} class="hover:!text-fg">{SITE.author.name}</a>
        </p>
      )
    }
    <p class="mt-3 text-lg font-medium tracking-tight text-fg sm:text-xl">{SITE.author.role}</p>
    <p class="mt-4 max-w-xs leading-normal text-muted">{SITE.author.bio}</p>

    <nav class="nav-scroll mt-12 lg:mt-16 lg:overflow-y-auto" aria-label="Primary">
      <ul class="space-y-3">
        {
          SITE.nav.map((item) => {
            const isActive =
              currentPath === item.href || currentPath.startsWith(item.href + '/');
            return (
              <li>
                <a
                  href={url(item.href)}
                  class:list={[
                    'group inline-flex items-center py-1 pr-1 no-underline',
                    isActive ? 'text-fg' : 'text-muted hover:!text-fg',
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  <span
                    class:list={[
                      'mr-4 inline-block h-px bg-muted transition-all duration-200 motion-reduce:transition-none group-hover:bg-fg group-hover:w-16',
                      isActive ? 'w-16 bg-fg' : 'w-8',
                    ]}
                    aria-hidden="true"
                  />
                  <span
                    class:list={[
                      'font-mono text-xs uppercase tracking-widest',
                      isActive ? 'font-semibold' : '',
                    ]}
                  >
                    {item.label}
                  </span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>

  <SocialIcons class="mt-12 lg:mt-0" />
</aside>
