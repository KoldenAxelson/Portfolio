---
// SideBar — identity + in-page section nav + typewriter bio.
// Only rendered when BaseLayout's `split` prop is true (homepage).
//
// Typewriter data flow: the messages live on per-element BioIndicator
// buttons rendered by the page (each carrying a `data-bio-messages` JSON
// payload). This script doesn't import the message pool — it discovers
// indicators in the DOM and drives the typewriter from whichever one is
// currently "active" (clicked, or auto-picked when its section scrolls
// into view).
import { SITE } from '@config';
import { url } from '@lib/url';

interface Props {
  sections?: { id: string; label: string }[];
}

const { sections = [] } = Astro.props;
---

<aside class="h-card pb-2 pt-12 lg:sticky lg:top-16 lg:max-h-[calc(100vh-4rem)] lg:w-1/2 lg:self-start lg:py-24">
  {/* h-card microformat: a machine-readable identity layer that stacks with
      JSON-LD. IndieWeb parsers, some search engines, and AI scrapers all
      pick it up. Classes are invisible to users; structure is unchanged. */}
  <div>
    <h1 class="text-4xl font-bold tracking-tight text-fg sm:text-5xl">
      <a href={url('/')} class="u-url hover:!text-fg">
        <span class="p-name">{SITE.author.name}</span>
      </a>
    </h1>
    <p class="p-job-title mt-3 text-lg font-medium tracking-tight text-fg sm:text-xl">{SITE.author.role}</p>

    {/* Real bio in static HTML; JS swaps it for the typewriter post-hydration.
        Hidden below `lg` to match the layout's single-column transition —
        the typewriter script bails on mobile anyway, and mobile visitors
        still get the full long-form bio when they scroll into the About
        section. The element stays in the DOM (display:none, not removed)
        so the h-card microformat and JSON-LD coverage are unaffected. */}
    <p
      data-bio-typer
      class="p-note mt-4 hidden min-h-[5.5rem] max-w-xs leading-normal text-muted lg:block"
    >{SITE.author.bio}<span data-bio-cursor aria-hidden="true" class="ml-0.5 inline-block w-[2px] h-[1.05em] translate-y-[3px] bg-current opacity-0 transition-opacity duration-300"></span></p>

    {/* Hidden h-card properties — picked up by parsers, invisible to users.
        The visible identity layer is above; these add machine fields the UI
        doesn't surface. */}
    <data class="u-email" value={SITE.author.email} hidden>{SITE.author.email}</data>

    {
      sections.length > 0 && (
        <nav class="nav-scroll mt-12 hidden lg:block lg:mt-16" aria-label="On this page">
          {/*
            Vertical dot-line progression. Each section is a clickable
            row with a dot in the gutter; lines between dots show
            visit/highlight state. Per-state styling is driven by JS
            setting `data-state` on each dot and line — the script lives
            in the inline <script> at the bottom of this file.

            Dot states:
              • future      — small grey (default)
              • passed      — small accent
              • current     — big accent
              • highlighted — accent ring (donut), for hover/focus on
                              non-current sections
            Line states:
              • grey            — between unvisited dots (default)
              • primary         — between visited dots
              • dashed-primary  — between current and a hovered future
                                  section, indicating the "jump path"
          */}
          <ol class="space-y-0">
            {sections.map((section, i) => (
              <li>
                <a
                  href={`#${section.id}`}
                  data-section-link={section.id}
                  class="group/nav-link flex items-center gap-3 py-1.5 text-muted no-underline transition-colors hover:!text-fg data-[active=true]:!text-fg"
                >
                  {/* Dot column — fixed 12px wide so big-current dots
                      align center with smaller passed/future dots. */}
                  <span class="flex h-3 w-3 shrink-0 items-center justify-center" aria-hidden="true">
                    <span
                      data-nav-dot
                      class="block h-1.5 w-1.5 rounded-full bg-border transition-all duration-200 motion-reduce:transition-none data-[state=passed]:bg-accent data-[state=current]:h-3 data-[state=current]:w-3 data-[state=current]:bg-accent data-[state=highlighted]:h-2.5 data-[state=highlighted]:w-2.5 data-[state=highlighted]:border-2 data-[state=highlighted]:border-accent data-[state=highlighted]:bg-transparent"
                    />
                  </span>
                  <span class="font-mono text-xs uppercase tracking-widest group-data-[active=true]:font-semibold">
                    {section.label}
                  </span>
                </a>
                {i < sections.length - 1 && (
                  <div class="flex w-3 justify-center" aria-hidden="true">
                    <span
                      data-nav-line
                      class="block h-3 w-px bg-border transition-all duration-200 motion-reduce:transition-none data-[state=primary]:bg-accent data-[state=dashed-primary]:w-0 data-[state=dashed-primary]:border-l data-[state=dashed-primary]:border-dashed data-[state=dashed-primary]:border-accent data-[state=dashed-primary]:bg-transparent"
                    />
                  </div>
                )}
              </li>
            ))}
          </ol>
        </nav>
      )
    }
  </div>
</aside>

{
  sections.length > 0 && (
    <script is:inline>
      function neofolioSidebarInit() {
        // Desktop behavior: sidebar typewriter + scroll auto-fire +
        // click-to-drive. Mobile BioIndicator clicks are handled in
        // TopNav.astro instead (open the navbar's mobile panel in "bio
        // mode" with the typewriter content there).
        //
        // The script handles VIEWPORT TRANSITIONS at runtime — when the
        // user resizes from desktop to mobile mid-session, the
        // IntersectionObserver gets torn down so it doesn't keep
        // randomly highlighting indicators on scroll while the sidebar
        // typewriter is hidden. Resizing back to desktop re-attaches it.

        const links = Array.from(document.querySelectorAll('[data-section-link]'));
        if (!links.length) return;
        const idToLink = new Map(
          links.map((l) => [l.getAttribute('data-section-link'), l]),
        );
        const sectionEls = links
          .map((l) => document.getElementById(l.getAttribute('data-section-link')))
          .filter(Boolean);
        if (!sectionEls.length) return;

        // Per-element indicators (BioIndicator.astro). Each carries its own
        // `data-bio-messages` JSON pool. Disabled indicators (no messages)
        // get filtered out of the scroll-pick pool so we never try to drive
        // the typewriter from an empty pool. Click handlers attached to all
        // indicators are harmless on disabled ones — the browser ignores
        // clicks on disabled buttons natively.
        const indicators = Array.from(
          document.querySelectorAll('[data-bio-indicator]'),
        );
        const sectionIdToIndicators = new Map();
        for (const indicator of indicators) {
          if (indicator.disabled) continue;
          const sectionEl = indicator.closest('section[id]');
          if (!sectionEl) continue;
          const id = sectionEl.id;
          if (!sectionIdToIndicators.has(id)) sectionIdToIndicators.set(id, []);
          sectionIdToIndicators.get(id).push(indicator);
        }

        // ---- Typewriter setup ----
        const bioEl = document.querySelector('[data-bio-typer]');
        const cursorEl = bioEl ? bioEl.querySelector('[data-bio-cursor]') : null;
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        let currentSection = null;
        let activeIndicator = null;
        let typingToken = 0;

        // Capture the static bio text rendered server-side. This is what we
        // restore when the user scrolls into a section that has no
        // indicators (e.g. About) — the "neutral state" of the typewriter.
        function getInitialBio() {
          if (!bioEl) return '';
          let s = '';
          for (const node of bioEl.childNodes) {
            if (node !== cursorEl && node.nodeType === Node.TEXT_NODE) s += node.textContent;
          }
          return s;
        }
        const defaultBio = getInitialBio();

        function sleep(ms) {
          return new Promise((r) => setTimeout(r, ms));
        }

        function pickRandom(arr) {
          if (!arr || !arr.length) return null;
          return arr[Math.floor(Math.random() * arr.length)];
        }

        function readMessages(indicator) {
          if (!indicator) return [];
          try {
            const parsed = JSON.parse(indicator.getAttribute('data-bio-messages') || '[]');
            return Array.isArray(parsed) ? parsed : [];
          } catch (e) {
            return [];
          }
        }

        function setText(text) {
          if (!bioEl) return;
          // Remove every text node before the cursor, then insert the new text.
          const children = Array.from(bioEl.childNodes);
          for (const node of children) {
            if (node !== cursorEl) bioEl.removeChild(node);
          }
          bioEl.insertBefore(document.createTextNode(text), cursorEl);
        }

        function visibleText() {
          if (!bioEl) return '';
          let s = '';
          for (const node of bioEl.childNodes) {
            if (node !== cursorEl && node.nodeType === Node.TEXT_NODE) s += node.textContent;
          }
          return s;
        }

        async function typeMessage(message) {
          const myToken = ++typingToken;
          if (!bioEl) return;

          if (reduceMotion) {
            setText(message);
            return;
          }

          // Animate cursor while typing/backspacing.
          if (cursorEl) cursorEl.style.opacity = '1';

          // Backspace existing text.
          let current = visibleText();
          while (current.length > 0 && typingToken === myToken) {
            current = current.slice(0, -1);
            setText(current);
            await sleep(12);
          }
          if (typingToken !== myToken) return;

          // Pause briefly between messages.
          await sleep(150);
          if (typingToken !== myToken) return;

          // Type new message.
          let typed = '';
          for (const ch of message) {
            if (typingToken !== myToken) return;
            typed += ch;
            setText(typed);
            const isPunct = /[.!?,;:]/.test(ch);
            await sleep(isPunct ? 140 : 28 + Math.random() * 24);
          }

          // Fade cursor after a beat.
          await sleep(800);
          if (typingToken !== myToken) return;
          if (cursorEl) cursorEl.style.opacity = '0';
        }

        // Track section indices for the dot/line state computation. The
        // dot/line visuals depend on BOTH the current section (set by the
        // scroll observer) AND the hovered section (set by mouseenter /
        // focus listeners below). Either change re-runs updateNavStates.
        let currentIndex = -1;
        let hoverIndex = null;

        function setSectionActive(id) {
          for (const [key, el] of idToLink) {
            el.setAttribute('data-active', key === id ? 'true' : 'false');
          }
          currentIndex = id == null
            ? -1
            : links.findIndex((l) => l.getAttribute('data-section-link') === id);
          updateNavStates();
        }

        const navLines = Array.from(document.querySelectorAll('[data-nav-line]'));

        function updateNavStates() {
          // Dots: each section gets one of four states. Current always
          // wins over highlighted so the user's actual location stays
          // visible even if they hover over their current section.
          for (let i = 0; i < links.length; i++) {
            const dot = links[i].querySelector('[data-nav-dot]');
            if (!dot) continue;
            let state = 'future';
            if (i === currentIndex) state = 'current';
            else if (i === hoverIndex) state = 'highlighted';
            else if (i < currentIndex) state = 'passed';
            dot.setAttribute('data-state', state);
          }
          // Lines: each line is between section i and i+1.
          //   • Hovering a future section dashes the path from current
          //     all the way through the hovered section's preceding line.
          //   • Otherwise: primary if both endpoints are visited, grey
          //     if both are unvisited.
          for (let i = 0; i < navLines.length; i++) {
            let state = 'grey';
            const inDashedPath =
              hoverIndex != null &&
              hoverIndex > currentIndex &&
              i + 1 > currentIndex &&
              i + 1 <= hoverIndex;
            if (inDashedPath) {
              state = 'dashed-primary';
            } else if (i + 1 <= currentIndex) {
              state = 'primary';
            }
            navLines[i].setAttribute('data-state', state);
          }
        }

        // Hover/focus on any nav link → highlight that section. Works
        // for keyboard (focus) and mouse (mouseenter).
        links.forEach((link, i) => {
          const enter = () => {
            hoverIndex = i;
            updateNavStates();
          };
          const leave = () => {
            if (hoverIndex === i) {
              hoverIndex = null;
              updateNavStates();
            }
          };
          link.addEventListener('mouseenter', enter);
          link.addEventListener('focus', enter);
          link.addEventListener('mouseleave', leave);
          link.addEventListener('blur', leave);
        });

        function setIndicatorActive(indicator) {
          activeIndicator = indicator;
          for (const ind of indicators) {
            ind.setAttribute('data-active', ind === indicator ? 'true' : 'false');
          }
        }

        // Drive the typewriter from a specific indicator. Picks a random
        // message from its pool, types it, and lights up the indicator.
        function driveFrom(indicator) {
          if (!indicator) return;
          const msg = pickRandom(readMessages(indicator));
          if (!msg) return;
          setIndicatorActive(indicator);
          typeMessage(msg);
        }

        // Restore the typewriter to its neutral state — the static bio that
        // was rendered server-side. Animated through the same typeMessage
        // path so it backspaces whatever thought was up and types the bio
        // back in. typeMessage bumps typingToken itself, which cancels any
        // in-flight typing from a previous section.
        function restoreDefault() {
          setIndicatorActive(null);
          if (defaultBio) typeMessage(defaultBio);
        }

        // Scroll-into-section: pick a random indicator within that section
        // and drive the typewriter from it. Section nav highlight tracks
        // section change separately so it always reflects the user's
        // scroll position. If a section has no indicators (e.g. About),
        // restore the static default bio rather than leaving whatever
        // thought was last typed for the previous section.
        function onSectionEnter(id) {
          if (id === currentSection) return;
          currentSection = id;
          setSectionActive(id);
          const pool = sectionIdToIndicators.get(id);
          const pick = pickRandom(pool);
          if (pick) {
            driveFrom(pick);
          } else {
            restoreDefault();
          }
        }

        // ─── Viewport-aware setup ──────────────────────────────────
        // The IntersectionObserver lives only while we're in desktop
        // mode. On a desktop→mobile resize we tear it down so it stops
        // auto-highlighting indicators on scroll (the sidebar typewriter
        // it would drive isn't visible on mobile, so the highlight is
        // confusing without an accompanying message — TopNav owns the
        // mobile bio behavior, click-only).
        const mq = window.matchMedia('(min-width: 1024px)');
        let observer = null;

        function setupObserver() {
          if (observer) return;
          observer = new IntersectionObserver(
            (entries) => {
              const intersecting = entries.filter((e) => e.isIntersecting);
              if (!intersecting.length) return;
              intersecting.sort(
                (a, b) => a.boundingClientRect.top - b.boundingClientRect.top,
              );
              const top = intersecting[0];
              if (top && top.target.id) onSectionEnter(top.target.id);
            },
            { rootMargin: '-30% 0px -55% 0px', threshold: 0 },
          );
          sectionEls.forEach((el) => observer.observe(el));
          // Prime with the current section.
          onSectionEnter(sectionEls[0].id);
        }

        function teardownObserver() {
          if (observer) {
            observer.disconnect();
            observer = null;
          }
          // Clear all desktop-driven visual state so nothing stale
          // (highlighted indicator, leftover typed thought) leaks into
          // the mobile experience after resize.
          setIndicatorActive(null);
          setSectionActive(null);
          currentSection = null;
        }

        function applyMode() {
          if (mq.matches) {
            setupObserver();
          } else {
            teardownObserver();
          }
        }

        // Click-to-drive: only fires in desktop mode. On mobile the
        // TopNav script intercepts these clicks for the navbar panel
        // (and our handler here would set state that's invisible
        // anyway since the sidebar typewriter is hidden).
        for (const indicator of indicators) {
          indicator.addEventListener('click', () => {
            if (!mq.matches) return;
            driveFrom(indicator);
          });
        }

        applyMode();
        mq.addEventListener('change', applyMode);
      }

      // Defer until DOM is parsed — the section anchors live in <main>,
      // which is rendered AFTER this script in the document.
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', neofolioSidebarInit);
      } else {
        neofolioSidebarInit();
      }
    </script>

  )
}
