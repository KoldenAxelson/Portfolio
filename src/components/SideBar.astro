---
// SideBar — identity + in-page section nav + typewriter bio.
// Only rendered when BaseLayout's `split` prop is true (homepage).
//
// Typewriter data flow: the messages live on per-element BioIndicator
// buttons rendered by the page (each carrying a `data-bio-messages` JSON
// payload). This script doesn't import the message pool — it discovers
// indicators in the DOM and drives the typewriter from whichever one is
// currently "active" (clicked, or auto-picked when its section scrolls
// into view).
import { SITE } from '@config';
import { url } from '@lib/url';

interface Props {
  sections?: { id: string; label: string }[];
}

const { sections = [] } = Astro.props;
---

<aside class="h-card lg:sticky lg:top-16 lg:max-h-[calc(100vh-4rem)] lg:w-1/2 lg:py-24 py-12">
  {/* h-card microformat: a machine-readable identity layer that stacks with
      JSON-LD. IndieWeb parsers, some search engines, and AI scrapers all
      pick it up. Classes are invisible to users; structure is unchanged. */}
  <div>
    <h1 class="text-4xl font-bold tracking-tight text-fg sm:text-5xl">
      <a href={url('/')} class="u-url hover:!text-fg">
        <span class="p-name">{SITE.author.name}</span>
      </a>
    </h1>
    <p class="p-job-title mt-3 text-lg font-medium tracking-tight text-fg sm:text-xl">{SITE.author.role}</p>

    {/* Real bio in static HTML; JS swaps it for the typewriter post-hydration. */}
    <p
      data-bio-typer
      class="p-note mt-4 min-h-[5.5rem] max-w-xs leading-normal text-muted"
    >{SITE.author.bio}<span data-bio-cursor aria-hidden="true" class="ml-0.5 inline-block w-[2px] h-[1.05em] translate-y-[3px] bg-current opacity-0 transition-opacity duration-300"></span></p>

    {/* Hidden h-card properties — picked up by parsers, invisible to users.
        The visible identity layer is above; these add machine fields the UI
        doesn't surface. */}
    <data class="u-email" value={SITE.author.email} hidden>{SITE.author.email}</data>

    {
      sections.length > 0 && (
        <nav class="nav-scroll mt-12 hidden lg:block lg:mt-16" aria-label="On this page">
          <ul class="space-y-3">
            {sections.map((section) => (
              <li>
                <a
                  href={`#${section.id}`}
                  data-section-link={section.id}
                  class="group inline-flex items-center py-1 pr-1 text-muted no-underline transition-colors hover:!text-fg data-[active=true]:!text-fg"
                >
                  <span
                    aria-hidden="true"
                    class="mr-4 inline-block h-px w-8 bg-muted transition-all duration-200 motion-reduce:transition-none group-hover:w-16 group-hover:bg-fg group-data-[active=true]:w-16 group-data-[active=true]:bg-fg"
                  />
                  <span class="font-mono text-xs uppercase tracking-widest group-data-[active=true]:font-semibold">
                    {section.label}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }
  </div>
</aside>

{
  sections.length > 0 && (
    <script is:inline>
      function neofolioSidebarInit() {
        // Bail on mobile: the sidebar isn't sticky there, the section nav is
        // hidden, and the typing animation would just type into a paragraph
        // that scrolls past before anyone reads it. The static bio stays put.
        const isLargeScreen = window.matchMedia('(min-width: 1024px)').matches;
        if (!isLargeScreen) return;

        const links = Array.from(document.querySelectorAll('[data-section-link]'));
        if (!links.length) return;
        const idToLink = new Map(
          links.map((l) => [l.getAttribute('data-section-link'), l]),
        );
        const sectionEls = links
          .map((l) => document.getElementById(l.getAttribute('data-section-link')))
          .filter(Boolean);
        if (!sectionEls.length) return;

        // Per-element indicators (BioIndicator.astro). Each carries its own
        // `data-bio-messages` JSON pool. Disabled indicators (no messages)
        // get filtered out of the scroll-pick pool so we never try to drive
        // the typewriter from an empty pool. Click handlers attached to all
        // indicators are harmless on disabled ones — the browser ignores
        // clicks on disabled buttons natively.
        const indicators = Array.from(
          document.querySelectorAll('[data-bio-indicator]'),
        );
        const sectionIdToIndicators = new Map();
        for (const indicator of indicators) {
          if (indicator.disabled) continue;
          const sectionEl = indicator.closest('section[id]');
          if (!sectionEl) continue;
          const id = sectionEl.id;
          if (!sectionIdToIndicators.has(id)) sectionIdToIndicators.set(id, []);
          sectionIdToIndicators.get(id).push(indicator);
        }

        // ---- Typewriter setup ----
        const bioEl = document.querySelector('[data-bio-typer]');
        const cursorEl = bioEl ? bioEl.querySelector('[data-bio-cursor]') : null;
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        let currentSection = null;
        let activeIndicator = null;
        let typingToken = 0;

        // Capture the static bio text rendered server-side. This is what we
        // restore when the user scrolls into a section that has no
        // indicators (e.g. About) — the "neutral state" of the typewriter.
        function getInitialBio() {
          if (!bioEl) return '';
          let s = '';
          for (const node of bioEl.childNodes) {
            if (node !== cursorEl && node.nodeType === Node.TEXT_NODE) s += node.textContent;
          }
          return s;
        }
        const defaultBio = getInitialBio();

        function sleep(ms) {
          return new Promise((r) => setTimeout(r, ms));
        }

        function pickRandom(arr) {
          if (!arr || !arr.length) return null;
          return arr[Math.floor(Math.random() * arr.length)];
        }

        function readMessages(indicator) {
          if (!indicator) return [];
          try {
            const parsed = JSON.parse(indicator.getAttribute('data-bio-messages') || '[]');
            return Array.isArray(parsed) ? parsed : [];
          } catch (e) {
            return [];
          }
        }

        function setText(text) {
          if (!bioEl) return;
          // Remove every text node before the cursor, then insert the new text.
          const children = Array.from(bioEl.childNodes);
          for (const node of children) {
            if (node !== cursorEl) bioEl.removeChild(node);
          }
          bioEl.insertBefore(document.createTextNode(text), cursorEl);
        }

        function visibleText() {
          if (!bioEl) return '';
          let s = '';
          for (const node of bioEl.childNodes) {
            if (node !== cursorEl && node.nodeType === Node.TEXT_NODE) s += node.textContent;
          }
          return s;
        }

        async function typeMessage(message) {
          const myToken = ++typingToken;
          if (!bioEl) return;

          if (reduceMotion) {
            setText(message);
            return;
          }

          // Animate cursor while typing/backspacing.
          if (cursorEl) cursorEl.style.opacity = '1';

          // Backspace existing text.
          let current = visibleText();
          while (current.length > 0 && typingToken === myToken) {
            current = current.slice(0, -1);
            setText(current);
            await sleep(12);
          }
          if (typingToken !== myToken) return;

          // Pause briefly between messages.
          await sleep(150);
          if (typingToken !== myToken) return;

          // Type new message.
          let typed = '';
          for (const ch of message) {
            if (typingToken !== myToken) return;
            typed += ch;
            setText(typed);
            const isPunct = /[.!?,;:]/.test(ch);
            await sleep(isPunct ? 140 : 28 + Math.random() * 24);
          }

          // Fade cursor after a beat.
          await sleep(800);
          if (typingToken !== myToken) return;
          if (cursorEl) cursorEl.style.opacity = '0';
        }

        function setSectionActive(id) {
          for (const [key, el] of idToLink) {
            el.setAttribute('data-active', key === id ? 'true' : 'false');
          }
        }

        function setIndicatorActive(indicator) {
          activeIndicator = indicator;
          for (const ind of indicators) {
            ind.setAttribute('data-active', ind === indicator ? 'true' : 'false');
          }
        }

        // Drive the typewriter from a specific indicator. Picks a random
        // message from its pool, types it, and lights up the indicator.
        function driveFrom(indicator) {
          if (!indicator) return;
          const msg = pickRandom(readMessages(indicator));
          if (!msg) return;
          setIndicatorActive(indicator);
          typeMessage(msg);
        }

        // Restore the typewriter to its neutral state — the static bio that
        // was rendered server-side. Animated through the same typeMessage
        // path so it backspaces whatever thought was up and types the bio
        // back in. typeMessage bumps typingToken itself, which cancels any
        // in-flight typing from a previous section.
        function restoreDefault() {
          setIndicatorActive(null);
          if (defaultBio) typeMessage(defaultBio);
        }

        // Clicking an indicator types one of ITS messages and highlights it.
        for (const indicator of indicators) {
          indicator.addEventListener('click', () => driveFrom(indicator));
        }

        // Scroll-into-section: pick a random indicator within that section
        // and drive the typewriter from it. Section nav highlight tracks
        // section change separately so it always reflects the user's
        // scroll position. If a section has no indicators (e.g. About),
        // restore the static default bio rather than leaving whatever
        // thought was last typed for the previous section.
        function onSectionEnter(id) {
          if (id === currentSection) return;
          currentSection = id;
          setSectionActive(id);
          const pool = sectionIdToIndicators.get(id);
          const pick = pickRandom(pool);
          if (pick) {
            driveFrom(pick);
          } else {
            restoreDefault();
          }
        }

        const observer = new IntersectionObserver(
          (entries) => {
            const intersecting = entries.filter((e) => e.isIntersecting);
            if (!intersecting.length) return;
            intersecting.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
            const top = intersecting[0];
            if (top && top.target.id) onSectionEnter(top.target.id);
          },
          { rootMargin: '-30% 0px -55% 0px', threshold: 0 },
        );
        sectionEls.forEach((el) => observer.observe(el));
        onSectionEnter(sectionEls[0].id);
      }

      // Defer until DOM is parsed — the section anchors live in <main>,
      // which is rendered AFTER this script in the document.
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', neofolioSidebarInit);
      } else {
        neofolioSidebarInit();
      }
    </script>

  )
}
