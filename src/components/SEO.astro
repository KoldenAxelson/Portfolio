---
// SEO + OpenGraph + JSON-LD all in one place.
// Pages pass in title/description/og; we handle the rest from src/config.
import { SITE, DEFAULT_OG_IMAGE } from '@config';
import { personId, websiteId } from '@lib/schema';

interface Props {
  title?: string;
  description?: string;
  /** Path or absolute URL. If relative, resolved against SITE.url. */
  image?: string;
  /** 'website' | 'article'. Defaults to 'website'. */
  type?: 'website' | 'article';
  /** For BlogPosting JSON-LD. */
  publishedTime?: Date;
  modifiedTime?: Date;
  /** Set true on pages we don't want indexed. */
  noindex?: boolean;
  /** JSON-LD blocks to inject — pages can add Person, BlogPosting, etc. */
  schema?: Record<string, unknown>[];
}

const {
  title,
  description = SITE.description,
  image = DEFAULT_OG_IMAGE,
  type = 'website',
  publishedTime,
  modifiedTime,
  noindex = false,
  schema = [],
} = Astro.props;

const fullTitle = title ? `${title} — ${SITE.title}` : SITE.title;
const canonical = new URL(Astro.url.pathname, SITE.url).toString();
const ogImage = image
  ? image.startsWith('http')
    ? image
    : new URL(image, SITE.url).toString()
  : undefined;

// Per-page schemas (BlogPosting, CreativeWork, hasOccupation Person on /cv)
// reference the canonical site Person and WebSite by @id via @lib/schema —
// that's what turns a pile of disconnected JSON-LD blobs into a graph that
// knowledge bases can resolve. Do not redeclare these entities elsewhere;
// reference them with `{ '@id': personId }` instead.

// Always inject a WebSite + Person JSON-LD block site-wide.
const baseSchema: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': websiteId,
    name: SITE.title,
    url: SITE.url,
    description: SITE.description,
    inLanguage: SITE.locale,
    author: { '@id': personId },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': personId,
    name: SITE.author.name,
    jobTitle: SITE.author.role,
    description: SITE.author.longBio,
    url: SITE.url,
    ...(SITE.author.email && { email: `mailto:${SITE.author.email}` }),
    ...(SITE.author.location && {
      address: { '@type': 'PostalAddress', addressLocality: SITE.author.location },
    }),
    sameAs: Object.values(SITE.links).filter((u) => u && u.startsWith('http')),
  },
];

const allSchema = [...baseSchema, ...schema];
---

<!-- Primary meta -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex,nofollow" />}

<!-- OpenGraph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
{ogImage && <meta property="og:image" content={ogImage} />}
<meta property="og:site_name" content={SITE.title} />
<meta property="og:locale" content={SITE.locale.replace('-', '_')} />
{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}
{SITE.links.twitter && (
  <meta name="twitter:creator" content={SITE.author.handle} />
)}

<!-- JSON-LD -->
{
  allSchema.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))
}
