---
import { SITE } from '@config';

interface Props {
  date: Date;
  /** 'short' (default) = "Apr 8, 2026". 'long' = "April 8, 2026". */
  format?: 'short' | 'long';
}

const { date, format = 'short' } = Astro.props;
const iso = date.toISOString();
const human = date.toLocaleDateString(SITE.locale, {
  month: format === 'short' ? 'short' : 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<time datetime={iso} class="whitespace-nowrap">{human}</time>
