---
import { SITE } from '@config';

interface Props {
  date: Date;
}

const { date } = Astro.props;
const iso = date.toISOString();
const human = date.toLocaleDateString(SITE.locale, {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---

<time datetime={iso} class="whitespace-nowrap">{human}</time>
