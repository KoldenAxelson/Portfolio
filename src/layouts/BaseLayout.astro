---
import { SITE } from '@config';
import { url } from '@lib/url';
import SEO from '@components/SEO.astro';
import SideBar from '@components/SideBar.astro';
import TopNav from '@components/TopNav.astro';
import Footer from '@components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  noindex?: boolean;
  schema?: Record<string, unknown>[];
  /**
   * Two-column layout with sticky sidebar (identity + in-page section nav).
   * Reserved for the homepage. Sub-pages should leave this false.
   */
  split?: boolean;
  /** In-page section anchors for the sidebar nav. Only used when split=true. */
  sections?: { id: string; label: string }[];
  /**
   * Use a wider content container (max-w-screen-xl instead of max-w-3xl).
   * Reserved for pages whose content is multi-column or app-like —
   * e.g. /network. Ignored when split=true.
   */
  wide?: boolean;
}

const {
  title,
  description,
  image,
  type,
  publishedTime,
  modifiedTime,
  noindex,
  schema,
  split = false,
  sections,
  wide = false,
} = Astro.props;
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    {/* Self-hosted Inter — preload the variable font so it's available for
        first paint. @font-face declaration lives in src/styles/global.css. */}
    <link
      rel="preload"
      href={url('/fonts/InterVariable.woff2')}
      as="font"
      type="font/woff2"
      crossorigin
    />

    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href={url('/rss.xml')} />
    <link
      rel="alternate"
      type="application/feed+json"
      title={`${SITE.title} (JSON Feed)`}
      href={url('/feed.json')}
    />

    {/* Browser chrome tint. Matches the paper-white / zinc-950 palette. */}
    <meta name="theme-color" content="#fafaf7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#09090b" media="(prefers-color-scheme: dark)" />

    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      noindex={noindex}
      schema={schema}
    />
  </head>
  <body
    class="leading-relaxed"
    style={`--noise-bg-light: url('${url('/textures/noise.png')}'); --noise-bg-dark: url('${url('/textures/noise-dark.png')}')`}
  >
    <a href="#main" class="skip-link">Skip to content</a>

    <TopNav />

    {
      split ? (
        <div class="mx-auto max-w-screen-xl px-6 lg:px-12">
          <div class="lg:flex lg:justify-between lg:gap-12">
            <SideBar sections={sections} />
            {/* Asymmetric vertical padding: sections inside <slot /> use
                `last:mb-0` so the final section has no bottom margin. We keep
                a moderate pb here for breathing room before the footer
                without piling 6rem on top of an already-zero section margin. */}
            <main id="main" class="pt-8 lg:w-1/2 lg:pt-24 lg:pb-12">
              <slot />
            </main>
          </div>
          <Footer />
        </div>
      ) : (
        <div class:list={['mx-auto px-6 py-12 lg:py-16', wide ? 'max-w-screen-xl lg:px-12' : 'max-w-3xl']}>
          <main id="main">
            <slot />
          </main>
          <Footer />
        </div>
      )
    }
  </body>
</html>
