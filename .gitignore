# Local Dev Storage
/private/
/_to_delete/

# AI chat proxy — compiled binary and Go build leftovers (build with
# `make ai-proxy`; never commit). The glob also catches stray toolchain
# artifacts like the zero-byte `ai-proxy-go-tmp-umask` probe file.
/ai-proxy/ai-proxy
/ai-proxy/ai-proxy-*

# Hugo build output
/public/
/resources/
.hugo_build.lock

# Downloaded toolchain (fetched by `make setup`)
/bin/

# Generated CSS (built by the Tailwind standalone binary at `make css`)
/assets/css/app.css

# Auto-generated by Hugo's esbuild (js.Build) for editor module resolution
/assets/jsconfig.json

# Secrets / local env
.env
.env.*
!.env.example

# OS / editor cruft
.DS_Store
.idea/
.fuse_hidden*

# wrangler / cloudflare
.wrangler/
.dev.vars

# Credentials — never commit. (Belt-and-suspenders: the AI feature keeps the
# proxy secret in env and the tunnel creds in ~/.cloudflared, not in the repo.)
*.key
*.pem
cloudflared/
*.tunnel.json
AI_PROXY_SECRET

# Fallow
.fallow/
.fallowrc.json
