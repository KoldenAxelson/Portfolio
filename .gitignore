# Hugo build output
/public/
/resources/
.hugo_build.lock

# Downloaded toolchain (fetched by `make setup`)
/bin/

# Generated CSS (built by the Tailwind standalone binary at `make css`)
/assets/css/app.css

# Auto-generated by Hugo's esbuild (js.Build) for editor module resolution
/assets/jsconfig.json

# Secrets / local env
.env
.env.*
!.env.example

# OS / editor cruft
.DS_Store
.idea/

# Leftover Astro-era cache (safe to delete: rm -rf .astro)
.astro/

# wrangler / cloudflare
.wrangler/
.dev.vars
