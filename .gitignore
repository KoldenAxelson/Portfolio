# build output
dist/
.astro/
.astro-stale-*/
.output/

# build input — staging folder for `make badges` at the project root.
# Leading slash anchors the rule so it doesn't also match `public/badges/`,
# which is the FINAL processed location and MUST be committed.
/badges/

# dependencies
node_modules/
.nm-old-*/
.vite-stale-*/
.pnp/
.pnp.js

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env
.env
.env.local
.env.*.local
!.env.example

# macOS
.DS_Store

# editors
.vscode/*
!.vscode/extensions.json
.idea/

# lighthouse — scripts/lighthouse.sh writes reports to .lighthouse/
.lighthouse/
.lighthouseci/
lighthouse-report.*.html
lighthouse-report.*.json

# wrangler / cloudflare
.wrangler/
.dev.vars
